lse;\n        allow update: if isOwner(uid)\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);\n      }\n\n      match /hiddenThreadMessages/{threadId}/messages/{messageId} {\n        allow read, create, update, delete: if isOwner(uid);\n      }\n    }\n\n    match /profiles/{uid} {\n      allow read: if true;\n\n      allow create, update: if isOwner(uid)\n        && request.resource.data.uid == uid;\n\n      allow delete: if isOwner(uid);\n    }\n\n    match /usernameClaims/{usernameLower} {\n      allow read: if true;\n\n      allow create: if signedIn()\n        && request.resource.data.uid == request.auth.uid\n        && isUsernameDocIdValid(usernameLower);\n\n      allow update: if signedIn()\n        && resource.data.uid == request.auth.uid\n        && request.resource.data.uid == resource.data.uid\n        && isUsernameDocIdValid(usernameLower);\n\n      allow delete: if signedIn()\n        && resource.data.uid == request.auth.uid;\n    }\n\n    match /products/{productId} {\n  // Allow the editor to safely check a generated product ID that does not exist yet,\n  // without exposing existing private/draft products.\n  allow get: if !exists(/databases/$(database)/documents/products/$(productId))\n    || canReadProductResource(productId);\n\n  allow list: if canReadProductResource(productId);\n\n  allow create: if productCreateIsAllowed(productId);\n\n  allow update: if productUpdateIsAllowed();\n\n  allow delete: if signedIn()\n    && resource.data.artistId == request.auth.uid\n    && resource.data.status != 'published';\n\n  match /reviews/{reviewId} {\n    allow read: if (get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'\n      && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public')\n      || (signedIn() && (\n        get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid\n        || resource.data.uid == request.auth.uid\n      ));\n\n    allow create: if signedIn()\n      && request.resource.data.uid == request.auth.uid\n      && request.resource.data.body is string\n      && request.resource.data.body.size() > 0\n      && request.resource.data.body.size() <= 5000\n      && (!('rating' in request.resource.data) || (request.resource.data.rating is number && request.resource.data.rating >= 0.5 && request.resource.data.rating <= 5));\n\n    allow update: if signedIn() && (\n      resource.data.uid == request.auth.uid\n      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'dislikeCount', 'replyCount', 'updatedAt'])\n    );\n    allow delete: if signedIn() && resource.data.uid == request.auth.uid;\n\n    match /reactions/{reactionId} {\n      allow read: if signedIn() && request.auth.uid == reactionId;\n      allow create, update: if signedIn()\n        && request.auth.uid == reactionId\n        && request.resource.data.uid == request.auth.uid\n        && request.resource.data.reaction in ['like', 'dislike'];\n      allow delete: if signedIn() && request.auth.uid == reactionId;\n    }\n\n    match /replies/{replyId} {\n      allow read: if (get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'\n        && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public')\n        || signedIn();\n\n      allow create: if signedIn()\n        && request.resource.data.uid == request.auth.uid\n        && request.resource.data.body is string\n        && request.resource.data.body.size() > 0\n        && request.resource.data.body.size() <= 1200\n        && (!('deleted' in request.resource.data) || request.resource.data.deleted == false);\n\n      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;\n    }\n  }\n\n  match /reactions/{reactionId} {\n    allow read: if true;\n    allow create, update: if signedIn()\n      && reactionId == request.auth.uid\n      && request.resource.data.uid == request.auth.uid\n      && (!('reaction' in request.resource.data) || request.resource.data.reaction in ['like', 'dislike', null]);\n    allow delete: if signedIn() && resource.data.uid == request.auth.uid;\n  }\n\n  match /comments/{commentId} {\n    allow read: if get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'\n      && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public';\n\n    allow create: if signedIn()\n      && request.resource.data.uid == request.auth.uid\n      && request.resource.data.body is string\n      && request.resource.data.body.size() > 0\n      && request.resource.data.body.size() <= 5000;\n\n    allow update, delete: if signedIn()\n      && resource.data.uid == request.auth.uid;\n  }\n\n  match /files/{fileId} {\n    allow read: if canReadProductById(productId);\n\n    allow create, update, delete: if signedIn()\n      && productOwnerById(productId)\n      && get(/databases/$(database)/documents/products/$(productId)).data.status != 'published';\n  }\n\n  match /contributors/{uid} {\n    allow read: if signedIn() && (\n        get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid\n        || request.auth.uid == uid\n      );\n\n    allow create, update, delete: if signedIn()\n      && get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid\n      && get(/databases/$(database)/documents/products/$(productId)).data.status != 'published';\n\n    match /productEngagement/{productId} {\n      allow read: if true;\n      allow write: if false;\n\n      match /users/{uid} {\n        allow read: if signedIn() && request.auth.uid == uid;\n        allow write: if false;\n      }\n    }\n\n  }\n}\n\n    match /pendingReview/{reviewArea}/items/{productId} {\n  allow read: if signedIn()\n    && (\n      !('sellerId' in resource.data)\n      || resource.data.sellerId == request.auth.u