esource.data.type in ['audio', 'video'];\n\n        allow update: if isThreadParticipant(threadId)\n          && request.resource.data.participantIds == resource.data.participantIds\n          && request.resource.data.createdBy == resource.data.createdBy\n          && request.resource.data.callerId == resource.data.callerId\n          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n            'status',\n            'answeredAt',\n            'startedAt',\n            'endedAt',\n            'endedBy',\n            'endReason',\n            'updatedAt'\n          ]);\n\n        allow delete: if false;\n\n        match /participants/{uid} {\n          allow read: if isThreadParticipant(threadId);\n\n          allow create, update: if isThreadParticipant(threadId)\n            && request.auth.uid == uid\n            && request.resource.data.uid == uid;\n\n          allow delete: if isThreadParticipant(threadId)\n            && request.auth.uid == uid;\n        }\n\n        match /offers/{uid} {\n          allow read: if isThreadParticipant(threadId);\n\n          allow create, update: if isThreadParticipant(threadId)\n            && request.auth.uid == uid\n            && request.resource.data.type == 'offer'\n            && request.resource.data.sdp is string;\n\n          allow delete: if false;\n        }\n\n        match /answers/{uid} {\n          allow read: if isThreadParticipant(threadId);\n\n          allow create, update: if isThreadParticipant(threadId)\n            && request.auth.uid == uid\n            && request.resource.data.type == 'answer'\n            && request.resource.data.sdp is string;\n\n          allow delete: if false;\n        }\n\n        match /candidates/{uid}/items/{candidateId} {\n          allow read: if isThreadParticipant(threadId);\n\n          allow create: if isThreadParticipant(threadId)\n            && request.auth.uid == uid\n            && request.resource.data.candidate is string;\n\n          allow update: if false;\n\n          allow delete: if isThreadParticipant(threadId)\n            && request.auth.uid == uid;\n        }\n      }\n    }\n\n\n    match /studioProjects/{projectId} {\n      allow get: if isStudioOwnerResource() || isStudioCollaboratorResource();\n      allow list: if isStudioOwnerResource() || isStudioCollaboratorResource();\n      allow create: if studioProjectCreateIsValid();\n      allow update: if isStudioOwnerResource() && studioProjectUpdateIsValid();\n      allow delete: if isStudioOwnerResource();\n    }\n\n    match /stageProjects/{projectId} {\n      allow get: if isStageOwnerResource() || isStageCollaboratorResource();\n      allow list: if signedIn();\n      allow create: if stageProjectCreateIsValid();\n      allow update: if isStageOwnerResource() && stageProjectUpdateIsValid();\n      allow delete: if isStageOwnerResource();\n    }\n\n    match /operations/keyRequiredInfo {\n      allow read: if true;\n      allow write: if false;\n    }\n    match /operations/bannerAlerts {\n      allow read: if true;\n      allow write: if false;\n    }\n\n    match /adminUsers/{uid} {\n      allow read: if isAdminClaim();\n      allow write: if false;\n    }\n\n    match /adminLogs/{logId} {\n      allow read: if hasAuditReadClaim() || hasRoleManageClaim();\n      allow write: if false;\n    }\n\n    match /productModeration/{moderationId} {\n      allow read: if hasProductReviewClaim();\n      allow write: if false;\n\n      match /events/{eventId} {\n        allow read: if hasProductReviewClaim();\n        allow write: if false;\n      }\n    }\n\n    match /orders/{orderId} {\n      allow read: if signedIn() && resource.data.uid == request.auth.uid;\n      allow write: if false;\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n\n    match /productEngagement/{productId} {\n      allow read: if true;\n      allow write: if false;\n\n      match /users/{uid} {\n        allow read: if signedIn() && request.auth.