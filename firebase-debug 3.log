[debug] [2026-05-30T01:12:42.244Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/melogic-records/rulesets {"name":"projects/melogic-records/rulesets/44599299-1922-4733-b07d-cc78bb00e694","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isAdminClaim() {\n      return signedIn() && request.auth.token.admin == true;\n    }\n\n    function isOwnerAdminRole() {\n      return isAdminClaim() && request.auth.token.adminRole in ['owner', 'admin'];\n    }\n\n    function hasProductReviewClaim() {\n      return isOwnerAdminRole() || (isAdminClaim() && request.auth.token.productReview == true);\n    }\n\n    function hasAuditReadClaim() {\n      return isOwnerAdminRole() || (isAdminClaim() && request.auth.token.auditRead == true);\n    }\n\n    function hasRoleManageClaim() {\n      return isAdminClaim() && request.auth.token.roleManage == true;\n    }\n\n    function isOwner(uid) {\n      return signedIn() && request.auth.uid == uid;\n    }\n\n    function threadPath(threadId) {\n      return /databases/$(database)/documents/threads/$(threadId);\n    }\n\n    function threadExists(threadId) {\n      return exists(threadPath(threadId));\n    }\n\n    function threadData(threadId) {\n      return get(threadPath(threadId)).data;\n    }\n\n    // Use this ONLY for thread subcollections.\n    function isThreadParticipant(threadId) {\n      return signedIn()\n        && threadExists(threadId)\n        && threadData(threadId).participantIds is list\n        && request.auth.uid in threadData(threadId).participantIds;\n    }\n\n    function isThreadOwner(threadId) {\n      return isThreadParticipant(threadId)\n        && threadData(threadId).createdBy == request.auth.uid;\n    }\n\n    // Use this for /threads/{threadId} parent document get/list/update rules.\n    function isThreadParticipantResource()