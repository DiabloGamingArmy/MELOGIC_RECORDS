# Firebase App Check reCAPTCHA Enterprise website key (public site key).
# Using two different Enterprise site keys on the same page can cause:
# "Invalid site key or not loaded in api.js" unless multi-key behavior is verified.
VITE_APPCHECK_RECAPTCHA_ENTERPRISE_SITE_KEY=6LdVxcosAAAAADHONHnIqfGEUIEumkR1A6DOgaPD
# Auth-form reCAPTCHA Enterprise website key for Sign In / Create Account / Google login verification.
# Recommended during stabilization: use the same Website score-based Enterprise key as App Check.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=6LfCgsssAAAAADPv2fFgoS9Eyi9G4jkyicLSuUOv
VITE_ENABLE_APP_CHECK=true
VITE_RECAPTCHA_ENTERPRISE_AUTH_ENABLED=true
# Never place RECAPTCHA_ENTERPRISE_API_KEY in Vite env files; keep it only in Firebase Functions secrets.
