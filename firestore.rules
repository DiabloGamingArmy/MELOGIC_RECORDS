rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function threadPath(threadId) {
      return /databases/$(database)/documents/threads/$(threadId);
    }

    function threadExists(threadId) {
      return exists(threadPath(threadId));
    }

    function threadData(threadId) {
      return get(threadPath(threadId)).data;
    }

    // Use this ONLY for thread subcollections.
    function isThreadParticipant(threadId) {
      return signedIn()
        && threadExists(threadId)
        && threadData(threadId).participantIds is list
        && request.auth.uid in threadData(threadId).participantIds;
    }

    function isThreadOwner(threadId) {
      return isThreadParticipant(threadId)
        && threadData(threadId).createdBy == request.auth.uid;
    }

    // Use this for /threads/{threadId} parent document get/list/update rules.
    function isThreadParticipantResource() {
      return signedIn()
        && resource.data.participantIds is list
        && request.auth.uid in resource.data.participantIds;
    }

    function isThreadOwnerResource() {
      return isThreadParticipantResource()
        && resource.data.createdBy == request.auth.uid;
    }

    function isThreadParticipantCreate() {
      return signedIn()
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds;
    }

    function participantSelfUpdateIsSafe(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastReadAt',
          'lastDeliveredAt',
          'typingUpdatedAt',
          'muted',
          'archived',
          'updatedAt',
          'displayName',
          'username',
          'avatarURL',
          'photoURL'
        ]);
    }

    function participantSafeThreadUpdateResource() {
      return isThreadParticipantResource()
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'updatedAt',
          'lastMessageAt',
          'lastMessageText',
          'lastMessageSenderId',
          'lastMessageType',
          'lastMessageAttachmentCount',
          'dmBlockState'
        ])
        && dmBlockStateUpdateIsSafe();
    }

    function dmBlockStateUpdateIsSafe() {
      let changed = request.resource.data.diff(resource.data).affectedKeys().hasAny(['dmBlockState']);
      let participantIds = resource.data.participantIds;
      let otherParticipant = participantIds[0] == request.auth.uid ? participantIds[1] : participantIds[0];
      return !changed || (
        resource.data.type == 'dm'
        && participantIds is list
        && participantIds.size() == 2
        && request.auth.uid in participantIds
        && (
          (
            request.resource.data.dmBlockState is map
            && request.resource.data.dmBlockState.blockedBy == request.auth.uid
            && request.resource.data.dmBlockState.blockedUid == otherParticipant
          )
          || (
            request.resource.data.dmBlockState == null
            && resource.data.dmBlockState is map
            && resource.data.dmBlockState.blockedBy == request.auth.uid
          )
        )
      );
    }

    function validMessageCreate() {
      let body = request.resource.data.body;
      let attachments = request.resource.data.attachments;
      let hasBody = body is string && body.size() > 0;
      let hasAttachments = attachments is list && attachments.size() > 0;
      return hasBody || hasAttachments;
    }

    function dmAllowsMessageCreate(threadId) {
      let thread = threadData(threadId);
      return !(thread.type == 'dm' && thread.dmBlockState is map);
    }

    function validMessageEdit() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'body',
          'edited',
          'editedAt',
          'updatedAt'
        ])
        && resource.data.senderId == request.auth.uid
        && !resource.data.deleted
        && (!(resource.data.attachments is list) || resource.data.attachments.size() == 0)
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1200
        && request.resource.data.edited == true;
    }

    function validMessageDeleteForEveryone(threadId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'body',
          'attachments',
          'deleted',
          'deletedAt',
          'deletedBy',
          'updatedAt'
        ])
        && (
          resource.data.senderId == request.auth.uid
          || threadData(threadId).createdBy == request.auth.uid
        )
        && request.resource.data.deleted == true
        && request.resource.data.deletedBy == request.auth.uid
        && request.resource.data.body == ''
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() == 0;
    }

    function isUsernameDocIdValid(usernameLower) {
      return request.resource.data.usernameLower == usernameLower
        && request.resource.data.username == usernameLower;
    }

    function productAllowedKeys() {
      return request.resource.data.keys().hasOnly([
        'id',
        'slug',
        'status',
        'visibility',

        'title',
        'shortDescription',
        'description',
        'version',
        'usageLicense',
        'productType',
        'productKind',
        'previewMode',
        'distributionMode',

        'categories',
        'genres',
        'tags',
        'categoryKeys',
        'genreKeys',
        'tagKeys',
        'searchKeywords',

        'artistId',
        'artistName',
        'artistDisplayName',
        'artistUsername',
        'artistProfilePath',
        'artistAvatarURL',
        'artistPhotoURL',
        'artistNameLower',
        'artistUsernameLower',

        'contributorIds',
        'contributorNames',
        'contributorCount',
        'pendingContributorIds',
        'contributorRequestCount',
        'sellerAgreement',
        'sellerAgreementAccepted',
        'sellerAgreementVersion',

        'coverPath',
        'thumbnailPath',
        'coverURL',
        'thumbnailURL',
        'galleryPaths',
        'previewAudioPaths',
        'previewVideoPaths',
        'downloadPath',
        'licensePath',
        'assetSummary',
        'primaryPreviewPath',
        'primaryPreviewType',
        'primaryPreviewDuration',
        'primaryDownloadPath',
        'primaryDownloadBytes',
        'previewAssignment',

        'priceCents',
        'payoutTargetCents',
        'currency',
        'isFree',
        'saleEnabled',
        'storefrontVisible',

        'dawCompatibility',
        'formatKeys',
        'formatNotes',
        'compatibilityNotes',
        'includedFiles',

        'releasedAt',
        'createdAt',
        'updatedAt',

        'publishedAt',
        'moderationStatus',
        'moderationSummary',
        'moderationReasons',
        'reviewedAt',
        'reviewedBy',

        'likeCount',
        'dislikeCount',
        'saveCount',
        'downloadCount',
        'commentCount',
        'shareCount',
        'followCount',
        'counts',

        'featured',
        'promoted',
        'salesCount',
        'revenue',
        'entitlementCount'
      ]);
    }

    function productStatusIsCreatorWritable() {
      return request.resource.data.status in [
        'draft',
        'review_pending',
        'pending_ai_review',
        'needs_changes',
        'rejected',
        'archived'
      ];
    }

    function productFieldShapesAreValid() {
      return request.resource.data.id is string
        && request.resource.data.id.size() > 0
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.artistId is string
        && request.resource.data.artistId == request.auth.uid
        && productStatusIsCreatorWritable()
        && request.resource.data.visibility in [
          'public',
          'private',
          'unlisted'
        ]
        && (!('slug' in request.resource.data) || request.resource.data.slug is string)
        && (!('shortDescription' in request.resource.data) || (
          request.resource.data.shortDescription is string
          && request.resource.data.shortDescription.size() <= 500
        ))
        && (!('description' in request.resource.data) || (
          request.resource.data.description is string
          && request.resource.data.description.size() <= 20000
        ))
        && (!('version' in request.resource.data) || request.resource.data.version is string)
        && (!('usageLicense' in request.resource.data) || request.resource.data.usageLicense is string)
        && (!('productType' in request.resource.data) || request.resource.data.productType is string)
        && (!('productKind' in request.resource.data) || request.resource.data.productKind is string)
        && (!('previewMode' in request.resource.data) || request.resource.data.previewMode is string)
        && (!('distributionMode' in request.resource.data) || request.resource.data.distributionMode is string)
        && (!('priceCents' in request.resource.data) || (
          request.resource.data.priceCents is number
          && request.resource.data.priceCents >= 0
          && request.resource.data.priceCents <= 10000000
        ))
        && (!('payoutTargetCents' in request.resource.data) || (
          request.resource.data.payoutTargetCents is number
          && request.resource.data.payoutTargetCents >= 0
          && request.resource.data.payoutTargetCents <= 10000000
        ))
        && (!('currency' in request.resource.data) || request.resource.data.currency in ['USD', 'EUR', 'GBP'])
        && (!('isFree' in request.resource.data) || request.resource.data.isFree is bool)
        && (!('saleEnabled' in request.resource.data) || request.resource.data.saleEnabled is bool)
        && (!('storefrontVisible' in request.resource.data) || request.resource.data.storefrontVisible is bool)
        && (!('tags' in request.resource.data) || (
          request.resource.data.tags is list
          && request.resource.data.tags.size() <= 50
        ))
        && (!('categories' in request.resource.data) || (
          request.resource.data.categories is list
          && request.resource.data.categories.size() <= 20
        ))
        && (!('genres' in request.resource.data) || (
          request.resource.data.genres is list
          && request.resource.data.genres.size() <= 20
        ))
        && (!('searchKeywords' in request.resource.data) || (
          request.resource.data.searchKeywords is list
          && request.resource.data.searchKeywords.size() <= 120
        ))
        && (!('categoryKeys' in request.resource.data) || request.resource.data.categoryKeys is list)
        && (!('genreKeys' in request.resource.data) || request.resource.data.genreKeys is list)
        && (!('tagKeys' in request.resource.data) || request.resource.data.tagKeys is list)
        && (!('dawCompatibility' in request.resource.data) || request.resource.data.dawCompatibility is list)
        && (!('formatKeys' in request.resource.data) || request.resource.data.formatKeys is list)
        && (!('contributorIds' in request.resource.data) || (
          request.resource.data.contributorIds is list
          && request.resource.data.contributorIds.size() <= 25
        ))
        && (!('contributorNames' in request.resource.data) || (
          request.resource.data.contributorNames is list
          && request.resource.data.contributorNames.size() <= 25
        ))
        && (!('contributorCount' in request.resource.data) || (
          request.resource.data.contributorCount is number
          && request.resource.data.contributorCount >= 0
          && request.resource.data.contributorCount <= 25
        ))
        && (!('pendingContributorIds' in request.resource.data) || (
          request.resource.data.pendingContributorIds is list
          && request.resource.data.pendingContributorIds.size() <= 25
        ))
        && (!('contributorRequestCount' in request.resource.data) || (
          request.resource.data.contributorRequestCount is number
          && request.resource.data.contributorRequestCount >= 0
          && request.resource.data.contributorRequestCount <= 25
        ))
        && (!('sellerAgreement' in request.resource.data) || request.resource.data.sellerAgreement is map)
        && (!('sellerAgreementAccepted' in request.resource.data) || request.resource.data.sellerAgreementAccepted is bool)
        && (!('sellerAgreementVersion' in request.resource.data) || request.resource.data.sellerAgreementVersion is string)
        && (!('coverPath' in request.resource.data) || request.resource.data.coverPath is string)
        && (!('thumbnailPath' in request.resource.data) || request.resource.data.thumbnailPath is string)
        && (!('coverURL' in request.resource.data) || request.resource.data.coverURL is string)
        && (!('thumbnailURL' in request.resource.data) || request.resource.data.thumbnailURL is string)
        && (!('galleryPaths' in request.resource.data) || (
          request.resource.data.galleryPaths is list
          && request.resource.data.galleryPaths.size() <= 24
        ))
        && (!('previewAudioPaths' in request.resource.data) || (
          request.resource.data.previewAudioPaths is list
          && request.resource.data.previewAudioPaths.size() <= 12
        ))
        && (!('previewVideoPaths' in request.resource.data) || (
          request.resource.data.previewVideoPaths is list
          && request.resource.data.previewVideoPaths.size() <= 8
        ))
        && (!('downloadPath' in request.resource.data) || request.resource.data.downloadPath is string)
        && (!('licensePath' in request.resource.data) || request.resource.data.licensePath is string)
        && (!('assetSummary' in request.resource.data) || request.resource.data.assetSummary is map)
        && (!('primaryPreviewPath' in request.resource.data) || request.resource.data.primaryPreviewPath is string)
        && (!('primaryPreviewType' in request.resource.data) || request.resource.data.primaryPreviewType is string)
        && (!('primaryPreviewDuration' in request.resource.data) || (
          request.resource.data.primaryPreviewDuration is number
          && request.resource.data.primaryPreviewDuration >= 0
        ))
        && (!('primaryDownloadPath' in request.resource.data) || request.resource.data.primaryDownloadPath is string)
        && (!('primaryDownloadBytes' in request.resource.data) || (
          request.resource.data.primaryDownloadBytes is number
          && request.resource.data.primaryDownloadBytes >= 0
        ))
        && (!('previewAssignment' in request.resource.data) || request.resource.data.previewAssignment is map)
        && (!('formatNotes' in request.resource.data) || (
          request.resource.data.formatNotes is string
          && request.resource.data.formatNotes.size() <= 5000
        ))
        && (!('compatibilityNotes' in request.resource.data) || (
          request.resource.data.compatibilityNotes is string
          && request.resource.data.compatibilityNotes.size() <= 5000
        ))
        && (!('includedFiles' in request.resource.data) || (
          request.resource.data.includedFiles is string
          && request.resource.data.includedFiles.size() <= 10000
        ));
    }

    function zeroOrMissing(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == 0;
    }

    function falseOrMissing(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == false;
    }

    function nullOrMissing(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == null;
    }

    function emptyStringNullOrMissing(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == ''
        || request.resource.data[field] == null;
    }

    function emptyListOrMissing(field) {
      return !(field in request.resource.data)
        || (
          request.resource.data[field] is list
          && request.resource.data[field].size() == 0
        );
    }

    function stableOrSafeDefault(field, defaultValue) {
      return !(field in request.resource.data)
        || (
          field in resource.data
          && request.resource.data[field] == resource.data[field]
        )
        || (
          !(field in resource.data)
          && request.resource.data[field] == defaultValue
        );
    }

    function stableZeroOrDefault(field) {
      return !(field in request.resource.data)
        || (
          field in resource.data
          && request.resource.data[field] == resource.data[field]
        )
        || (
          !(field in resource.data)
          && request.resource.data[field] == 0
        );
    }

    function stableFalseOrDefault(field) {
      return !(field in request.resource.data)
        || (
          field in resource.data
          && request.resource.data[field] == resource.data[field]
        )
        || (
          !(field in resource.data)
          && request.resource.data[field] == false
        );
    }

    function stableNullOrDefault(field) {
      return !(field in request.resource.data)
        || (
          field in resource.data
          && request.resource.data[field] == resource.data[field]
        )
        || (
          !(field in resource.data)
          && request.resource.data[field] == null
        );
    }

    function stableEmptyStringNullOrDefault(field) {
      return !(field in request.resource.data)
        || (
          field in resource.data
          && request.resource.data[field] == resource.data[field]
        )
        || (
          !(field in resource.data)
          && (
            request.resource.data[field] == ''
            || request.resource.data[field] == null
          )
        );
    }

    function stableEmptyListOrDefault(field) {
      return !(field in request.resource.data)
        || (
          field in resource.data
          && request.resource.data[field] == resource.data[field]
        )
        || (
          !(field in resource.data)
          && request.resource.data[field] is list
          && request.resource.data[field].size() == 0
        );
    }

    function safeCountsMapCreate() {
      return !('counts' in request.resource.data)
        || (
          request.resource.data.counts is map
          && request.resource.data.counts.keys().hasOnly([
            'likes',
            'dislikes',
            'saves',
            'shares',
            'comments',
            'downloads',
            'follows'
          ])
          && (!('likes' in request.resource.data.counts) || request.resource.data.counts.likes == 0)
          && (!('dislikes' in request.resource.data.counts) || request.resource.data.counts.dislikes == 0)
          && (!('saves' in request.resource.data.counts) || request.resource.data.counts.saves == 0)
          && (!('shares' in request.resource.data.counts) || request.resource.data.counts.shares == 0)
          && (!('comments' in request.resource.data.counts) || request.resource.data.counts.comments == 0)
          && (!('downloads' in request.resource.data.counts) || request.resource.data.counts.downloads == 0)
          && (!('follows' in request.resource.data.counts) || request.resource.data.counts.follows == 0)
        );
    }

    function safeCountsMapUpdate() {
      return !('counts' in request.resource.data)
        || (
          'counts' in resource.data
          && request.resource.data.counts == resource.data.counts
        )
        || (
          !('counts' in resource.data)
          && safeCountsMapCreate()
        );
    }

    function safeModerationStatusCreate() {
      return !('moderationStatus' in request.resource.data)
        || request.resource.data.moderationStatus == null
        || request.resource.data.moderationStatus == ''
        || request.resource.data.moderationStatus == 'not_submitted'
        || request.resource.data.moderationStatus == 'pending'
        || request.resource.data.moderationStatus == 'queued';
    }

    function isProductReviewSubmission() {
      return resource.data.status in [
          'draft',
          'needs_changes',
          'rejected',
          'review_pending',
          'pending_ai_review'
        ]
        && request.resource.data.status in [
          'review_pending',
          'pending_ai_review'
        ];
    }

    function safeModerationStatusUpdate() {
      return !('moderationStatus' in request.resource.data)
        || (
          'moderationStatus' in resource.data
          && request.resource.data.moderationStatus == resource.data.moderationStatus
        )
        || (
          !('moderationStatus' in resource.data)
          && safeModerationStatusCreate()
        )
        || (
          isProductReviewSubmission()
          && (
            request.resource.data.moderationStatus == 'pending'
            || request.resource.data.moderationStatus == 'queued'
            || request.resource.data.moderationStatus == null
            || request.resource.data.moderationStatus == ''
          )
        );
    }

    function safeModerationSummaryUpdate() {
      return stableEmptyStringNullOrDefault('moderationSummary')
        || (
          isProductReviewSubmission()
          && (
            request.resource.data.moderationSummary == ''
            || request.resource.data.moderationSummary == null
          )
        );
    }

    function safeModerationReasonsUpdate() {
      return stableEmptyListOrDefault('moderationReasons')
        || (
          isProductReviewSubmission()
          && request.resource.data.moderationReasons is list
          && request.resource.data.moderationReasons.size() == 0
        );
    }

    function safeReviewedAtUpdate() {
      return stableNullOrDefault('reviewedAt')
        || (
          isProductReviewSubmission()
          && request.resource.data.reviewedAt == null
        );
    }

    function safeReviewedByUpdate() {
      return stableEmptyStringNullOrDefault('reviewedBy')
        || (
          isProductReviewSubmission()
          && (
            request.resource.data.reviewedBy == ''
            || request.resource.data.reviewedBy == null
          )
        );
    }

    function safePublishedAtUpdate() {
      return stableNullOrDefault('publishedAt')
        || (
          request.resource.data.status != 'published'
          && request.resource.data.publishedAt == null
        );
    }

    function productServerFieldsSafeOnCreate() {
      return safeModerationStatusCreate()
        && emptyStringNullOrMissing('moderationSummary')
        && emptyListOrMissing('moderationReasons')
        && nullOrMissing('reviewedAt')
        && emptyStringNullOrMissing('reviewedBy')
        && nullOrMissing('publishedAt')

        && zeroOrMissing('likeCount')
        && zeroOrMissing('dislikeCount')
        && zeroOrMissing('saveCount')
        && zeroOrMissing('downloadCount')
        && zeroOrMissing('commentCount')
        && zeroOrMissing('shareCount')
        && zeroOrMissing('followCount')
        && safeCountsMapCreate()

        && falseOrMissing('featured')
        && falseOrMissing('promoted')
        && zeroOrMissing('salesCount')
        && zeroOrMissing('revenue')
        && zeroOrMissing('entitlementCount');
    }

    function productServerFieldsSafeOnUpdate() {
      return safeModerationStatusUpdate()
        && safeModerationSummaryUpdate()
        && safeModerationReasonsUpdate()
        && safeReviewedAtUpdate()
        && safeReviewedByUpdate()
        && safePublishedAtUpdate()

        && stableZeroOrDefault('likeCount')
        && stableZeroOrDefault('dislikeCount')
        && stableZeroOrDefault('saveCount')
        && stableZeroOrDefault('downloadCount')
        && stableZeroOrDefault('commentCount')
        && stableZeroOrDefault('shareCount')
        && stableZeroOrDefault('followCount')
        && safeCountsMapUpdate()

        && stableFalseOrDefault('featured')
        && stableFalseOrDefault('promoted')
        && stableZeroOrDefault('salesCount')
        && stableZeroOrDefault('revenue')
        && stableZeroOrDefault('entitlementCount');
    }

    function creatorIdentityIsStable() {
      return resource.data.artistId == request.auth.uid
        && request.resource.data.artistId == resource.data.artistId
        && request.resource.data.artistProfilePath == resource.data.artistProfilePath;
    }

    function productCreateIsAllowed(productId) {
      return signedIn()
        && request.resource.data.id == productId
        && request.resource.data.artistId == request.auth.uid
        && productAllowedKeys()
        && productFieldShapesAreValid()
        && productServerFieldsSafeOnCreate()
        && request.resource.data.status != 'published';
    }

    function productUpdateIsAllowed() {
      return signedIn()
        && resource.data.artistId == request.auth.uid
        && resource.data.status != 'published'
        && creatorIdentityIsStable()
        && productAllowedKeys()
        && productFieldShapesAreValid()
        && productServerFieldsSafeOnUpdate()
        && request.resource.data.status != 'published';
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /entitlements/{productId} {
        allow read, write: if isOwner(uid);
      }

      match /agreementAcceptances/{agreementKey} {
        allow read, write: if isOwner(uid);
      }

      match /signedForms/{formKey} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && request.resource.data.signedBy == uid
          && request.resource.data.accepted == true
          && request.resource.data.agreementId is string
          && request.resource.data.version is string
          && request.resource.data.storagePath is string
          && request.resource.data.formKey == formKey;

        allow update: if isOwner(uid)
          && resource.data.signedBy == uid
          && request.resource.data.signedBy == resource.data.signedBy
          && request.resource.data.agreementId == resource.data.agreementId
          && request.resource.data.version == resource.data.version
          && request.resource.data.storagePath == resource.data.storagePath
          && request.resource.data.formKey == resource.data.formKey
          && request.resource.data.accepted == true;

        allow delete: if false;
      }

      match /inboxThreads/{threadId} {
        allow read, write: if isOwner(uid);
      }

      match /blockedUsers/{targetUid} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /systemNotifications/{notificationId} {
        allow read: if isOwner(uid);
        allow create, delete: if false;
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      }

      match /hiddenThreadMessages/{threadId}/messages/{messageId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /profiles/{uid} {
      allow read: if true;

      allow create, update: if isOwner(uid)
        && request.resource.data.uid == uid;

      allow delete: if isOwner(uid);
    }

    match /usernameClaims/{usernameLower} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && isUsernameDocIdValid(usernameLower);

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && isUsernameDocIdValid(usernameLower);

      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if (resource.data.status == 'published' && resource.data.visibility == 'public')
        || (signedIn() && resource.data.artistId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.artistId == request.auth.uid
        && (!('status' in request.resource.data) || request.resource.data.status in [
          'draft',
          'review_pending',
          'pending_ai_review',
          'needs_changes',
          'rejected',
          'archived'
        ])
        && (!('publishedAt' in request.resource.data) || request.resource.data.publishedAt == null);

      allow update: if signedIn()
        && resource.data.artistId == request.auth.uid
        && request.resource.data.artistId == resource.data.artistId
        && (!('status' in request.resource.data) || request.resource.data.status in [
          'draft',
          'review_pending',
          'pending_ai_review',
          'needs_changes',
          'rejected',
          'archived'
        ])
        && (!('publishedAt' in request.resource.data)
          || request.resource.data.publishedAt == resource.data.publishedAt
          || request.resource.data.publishedAt == null);

      allow delete: if signedIn()
        && resource.data.artistId == request.auth.uid
        && resource.data.status != 'published';

      match /reviews/{reviewId} {
        allow read: if signedIn()
          && get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid;

        allow write: if false;
      }

      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'
          && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public';

        allow create: if signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 5000;

        allow update, delete: if signedIn()
          && resource.data.uid == request.auth.uid;
      }

      match /files/{fileId} {
        allow read: if (get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'
            && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public')
          || (signedIn() && get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid);

        allow create, update, delete: if signedIn()
          && get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid
          && get(/databases/$(database)/documents/products/$(productId)).data.status != 'published';
      }

      match /contributors/{uid} {
        allow read: if signedIn() && (
            get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid
            || request.auth.uid == uid
          );

        allow create, update, delete: if signedIn()
          && get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid
          && get(/databases/$(database)/documents/products/$(productId)).data.status != 'published';
      }
    }

    match /pendingReview/{reviewArea}/items/{productId} {
      allow read: if signedIn()
        && resource.data.sellerId == request.auth.uid;

      allow create: if signedIn()
        && reviewArea == 'marketplace'
        && request.resource.data.productId == productId
        && request.resource.data.sellerId == request.auth.uid;

      allow update: if signedIn()
        && resource.data.sellerId == request.auth.uid
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.productId == resource.data.productId;

      allow delete: if false;
    }

    match /platformSettings/{settingId} {
      allow read: if settingId in [
        'marketplacePricing',
        'marketplaceSellerAgreement'
      ];

      allow write: if false;
    }

    match /threads/{threadId} {
      allow get, list: if isThreadParticipantResource();

      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isThreadParticipantCreate()
        && request.resource.data.type in ['dm', 'group']
        && (!('status' in request.resource.data) || request.resource.data.status in ['active', 'archived'])
        && (!('participantCount' in request.resource.data)
          || request.resource.data.participantCount == request.resource.data.participantIds.size());

      allow update: if isThreadOwnerResource()
        || participantSafeThreadUpdateResource();

      allow delete: if false;

      match /participants/{uid} {
        allow read: if isThreadParticipant(threadId);

        allow create: if signedIn()
          && isThreadParticipant(threadId)
          && request.resource.data.uid == uid
          && (
            request.auth.uid == uid
            || isThreadOwner(threadId)
          );

        allow update: if isThreadOwner(threadId)
          || (
            signedIn()
            && isThreadParticipant(threadId)
            && participantSelfUpdateIsSafe(uid)
          );

        allow delete: if isThreadOwner(threadId);
      }

      match /messages/{messageId} {
        allow read: if isThreadParticipant(threadId);

        allow create: if isThreadParticipant(threadId)
          && request.resource.data.senderId == request.auth.uid
          && validMessageCreate()
          && dmAllowsMessageCreate(threadId);

        allow update: if isThreadParticipant(threadId)
          && (
            validMessageEdit()
            || validMessageDeleteForEveryone(threadId)
          );

        allow delete: if false;

        match /reactions/{reactionId} {
          allow read: if isThreadParticipant(threadId);

          allow create, update: if isThreadParticipant(threadId)
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.emoji is string
            && request.resource.data.emoji.size() > 0
            && request.resource.data.emoji.size() <= 16;

          allow delete: if isThreadParticipant(threadId)
            && resource.data.uid == request.auth.uid;
        }
      }

      match /typing/{uid} {
        allow read: if isThreadParticipant(threadId);

        allow create, update, delete: if signedIn()
          && isThreadParticipant(threadId)
          && request.auth.uid == uid;
      }

      match /calls/{callId} {
        allow read: if isThreadParticipant(threadId);

        allow create: if isThreadParticipant(threadId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.callerId == request.auth.uid
          && request.resource.data.participantIds is list
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.status in [
            'ringing',
            'accepted',
            'active',
            'declined',
            'missed',
            'ended',
            'failed'
          ]
          && request.resource.data.type in ['audio', 'video'];

        allow update: if isThreadParticipant(threadId)
          && request.resource.data.participantIds == resource.data.participantIds
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.callerId == resource.data.callerId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'answeredAt',
            'startedAt',
            'endedAt',
            'endedBy',
            'endReason',
            'updatedAt'
          ]);

        allow delete: if false;

        match /participants/{uid} {
          allow read: if isThreadParticipant(threadId);

          allow create, update: if isThreadParticipant(threadId)
            && request.auth.uid == uid
            && request.resource.data.uid == uid;

          allow delete: if isThreadParticipant(threadId)
            && request.auth.uid == uid;
        }

        match /offers/{uid} {
          allow read: if isThreadParticipant(threadId);

          allow create, update: if isThreadParticipant(threadId)
            && request.auth.uid == uid
            && request.resource.data.type == 'offer'
            && request.resource.data.sdp is string;

          allow delete: if false;
        }

        match /answers/{uid} {
          allow read: if isThreadParticipant(threadId);

          allow create, update: if isThreadParticipant(threadId)
            && request.auth.uid == uid
            && request.resource.data.type == 'answer'
            && request.resource.data.sdp is string;

          allow delete: if false;
        }

        match /candidates/{uid}/items/{candidateId} {
          allow read: if isThreadParticipant(threadId);

          allow create: if isThreadParticipant(threadId)
            && request.auth.uid == uid
            && request.resource.data.candidate is string;

          allow update: if false;

          allow delete: if isThreadParticipant(threadId)
            && request.auth.uid == uid;
        }
      }
    }

    match /productModeration/{moderationId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
