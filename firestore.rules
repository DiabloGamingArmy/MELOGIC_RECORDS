rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function threadPath(threadId) {
      return /databases/$(database)/documents/threads/$(threadId);
    }

    function threadExists(threadId) {
      return exists(threadPath(threadId));
    }

    function threadData(threadId) {
      return get(threadPath(threadId)).data;
    }

    function isThreadParticipant(threadId) {
      return signedIn()
        && threadExists(threadId)
        && request.auth.uid in threadData(threadId).participantIds;
    }

    function isThreadParticipantResource() {
      return signedIn()
        && resource.data.participantIds is list
        && request.auth.uid in resource.data.participantIds;
    }

    function isThreadParticipantCreate() {
      return signedIn()
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds;
    }

    function isThreadParticipantAfter() {
      return signedIn()
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds;
    }

    function isThreadOwnerResource() {
      return isThreadParticipantResource()
        && resource.data.createdBy == request.auth.uid;
    }

    function participantSafeThreadUpdateResource() {
      return isThreadParticipantResource()
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'updatedAt',
          'lastMessageAt',
          'lastMessageText',
          'lastMessageSenderId',
          'lastMessageType'
        ]);
    }

    function isThreadParticipantByParent(threadId) {
      return signedIn()
        && threadExists(threadId)
        && request.auth.uid in threadData(threadId).participantIds;
    }

    function isThreadOwnerByParent(threadId) {
      return isThreadParticipantByParent(threadId)
        && threadData(threadId).createdBy == request.auth.uid;
    }

    function participantSelfUpdateIsSafe(uid) {
      return request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'lastReadAt',
          'lastDeliveredAt',
          'typingUpdatedAt',
          'muted',
          'archived',
          'updatedAt',
          'displayName',
          'username',
          'avatarURL',
          'photoURL'
        ]);
    }

    function validMessageCreate() {
      let body = request.resource.data.body;
      let attachments = request.resource.data.attachments;
      let hasBody = body is string && body.size() > 0;
      let hasAttachments = attachments is list && attachments.size() > 0;
      return hasBody || hasAttachments;
    }

    function isUsernameDocIdValid(usernameLower) {
      return request.resource.data.usernameLower == usernameLower
        && request.resource.data.username == usernameLower;
    }

    function productCreateAllowedKeys() {
      return request.resource.data.keys().hasOnly([
        'id',
        'slug',
        'status',
        'visibility',
        'title',
        'shortDescription',
        'description',
        'productType',
        'categories',
        'genres',
        'tags',
        'artistId',
        'artistName',
        'artistDisplayName',
        'artistUsername',
        'artistProfilePath',
        'artistAvatarURL',
        'artistPhotoURL',
        'contributorIds',
        'contributorNames',
        'contributorCount',
        'coverPath',
        'thumbnailPath',
        'coverURL',
        'thumbnailURL',
        'galleryPaths',
        'previewAudioPaths',
        'previewVideoPaths',
        'downloadPath',
        'licensePath',
        'priceCents',
        'currency',
        'isFree',
        'titleLower',
        'artistNameLower',
        'artistUsernameLower',
        'searchKeywords',
        'categoryKeys',
        'genreKeys',
        'tagKeys',
        'dawCompatibility',
        'formatKeys',
        'releasedAt',
        'createdAt',
        'updatedAt',
        'moderationStatus',
        'moderationSummary',
        'moderationReasons',
        'reviewedAt',
        'reviewedBy',
        'publishedAt',
        'saleEnabled',
        'storefrontVisible',
        'formatNotes',
        'compatibilityNotes',
        'includedFiles'
      ]);
    }

    function productFieldShapesAreValid() {
      return request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && (!('shortDescription' in request.resource.data) || (request.resource.data.shortDescription is string && request.resource.data.shortDescription.size() <= 500))
        && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 20000))
        && (!('priceCents' in request.resource.data) || (request.resource.data.priceCents is number && request.resource.data.priceCents >= 0))
        && (!('status' in request.resource.data) || request.resource.data.status in ['draft', 'review_pending', 'published', 'rejected', 'needs_changes', 'archived'])
        && (!('visibility' in request.resource.data) || request.resource.data.visibility in ['public', 'private', 'unlisted'])
        && (!('tags' in request.resource.data) || (request.resource.data.tags is list && request.resource.data.tags.size() <= 50))
        && (!('categories' in request.resource.data) || (request.resource.data.categories is list && request.resource.data.categories.size() <= 20))
        && (!('genres' in request.resource.data) || (request.resource.data.genres is list && request.resource.data.genres.size() <= 20));
    }

    function protectedProductFieldsUnchanged() {
      return request.resource.data.likeCount == resource.data.likeCount
        && request.resource.data.dislikeCount == resource.data.dislikeCount
        && request.resource.data.saveCount == resource.data.saveCount
        && request.resource.data.downloadCount == resource.data.downloadCount
        && request.resource.data.commentCount == resource.data.commentCount
        && request.resource.data.counts == resource.data.counts
        && request.resource.data.featured == resource.data.featured
        && request.resource.data.promoted == resource.data.promoted
        && request.resource.data.moderationStatus == resource.data.moderationStatus
        && request.resource.data.reviewedAt == resource.data.reviewedAt
        && request.resource.data.reviewedBy == resource.data.reviewedBy
        && request.resource.data.salesCount == resource.data.salesCount
        && request.resource.data.revenue == resource.data.revenue
        && request.resource.data.entitlementCount == resource.data.entitlementCount;
    }

    

    function featuredItemsShapeValid() {
      return !('featuredItems' in request.resource.data)
        || (
          request.resource.data.featuredItems is map
          && (!('enabled' in request.resource.data.featuredItems) || request.resource.data.featuredItems.enabled is bool)
          && (!('productIds' in request.resource.data.featuredItems) || (
            request.resource.data.featuredItems.productIds is list
            && request.resource.data.featuredItems.productIds.size() <= 3
          ))
        );
    }

    function publicProfileUpdateAllowed(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.roleLabel == resource.data.roleLabel
        && request.resource.data.stats == resource.data.stats
        && featuredItemsShapeValid()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'displayName',
          'username',
          'usernameLower',
          'bio',
          'avatarPath',
          'avatarURL',
          'bannerPath',
          'bannerURL',
          'location',
          'website',
          'socials',
          'featuredItems',
          'updatedAt'
        ]);
    }

    function creatorIdentityIsStable() {
      return request.resource.data.artistId == resource.data.artistId
        && request.resource.data.artistId == request.auth.uid
        && request.resource.data.artistProfilePath == resource.data.artistProfilePath;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /inboxThreads/{threadId} {
        allow read, list, get: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /systemNotifications/{notificationId} {
        allow read: if isOwner(uid);
        allow create, delete: if false;
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readAt']);
      }
    }

    match /profiles/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if publicProfileUpdateAllowed(uid);
      allow delete: if isOwner(uid);
    }

    match /usernameClaims/{usernameLower} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && isUsernameDocIdValid(usernameLower);
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && isUsernameDocIdValid(usernameLower);
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if (resource.data.status == 'published' && resource.data.visibility == 'public')
        || (signedIn() && resource.data.artistId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.artistId == request.auth.uid
        && productCreateAllowedKeys()
        && productFieldShapesAreValid()
        && request.resource.data.status != 'published';
      // TODO(security): move production publish transitions to a callable Cloud Function.
      allow update: if signedIn()
        && resource.data.artistId == request.auth.uid
        && creatorIdentityIsStable()
        && productCreateAllowedKeys()
        && productFieldShapesAreValid()
        && protectedProductFieldsUnchanged()
        && request.resource.data.status != 'published';
      allow delete: if signedIn() && resource.data.artistId == request.auth.uid;
    }

    match /threads/{threadId} {
      allow get, list: if isThreadParticipantResource();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isThreadParticipantCreate()
        && request.resource.data.participantCount == request.resource.data.participantIds.size()
        && request.resource.data.status in ['active', 'archived']
        && request.resource.data.type in ['dm', 'group'];
      allow update: if isThreadOwnerResource() || participantSafeThreadUpdateResource();
      allow delete: if false;

      match /participants/{uid} {
        allow read: if isThreadParticipantByParent(threadId);
        allow create: if signedIn()
          && isThreadParticipantByParent(threadId)
          && request.resource.data.uid == uid
          && (
            request.auth.uid == uid
            || isThreadOwnerByParent(threadId)
          );
        allow update: if isThreadOwnerByParent(threadId)
          || (
            signedIn()
            && request.auth.uid == uid
            && isThreadParticipantByParent(threadId)
            && participantSelfUpdateIsSafe(uid)
          );
        allow delete: if isThreadOwnerByParent(threadId);
      }

      match /messages/{messageId} {
        allow read: if isThreadParticipantByParent(threadId);
        allow create: if isThreadParticipantByParent(threadId)
          && request.resource.data.senderId == request.auth.uid
          && validMessageCreate();
        allow update, delete: if isThreadParticipantByParent(threadId)
          && resource.data.senderId == request.auth.uid;
      }

      match /typing/{uid} {
        allow read: if isThreadParticipantByParent(threadId);
        allow create, update, delete: if signedIn()
          && request.auth.uid == uid
          && isThreadParticipantByParent(threadId);
      }

      match /calls/{callId} {
        allow read: if isThreadParticipantByParent(threadId);
        allow create: if isThreadParticipantByParent(threadId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.callerId == request.auth.uid
          && request.resource.data.participantIds is list
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.status in ['ringing', 'accepted', 'active', 'declined', 'missed', 'ended', 'failed']
          && request.resource.data.type in ['audio', 'video'];
        allow update: if isThreadParticipantByParent(threadId)
          && request.resource.data.participantIds == resource.data.participantIds
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.callerId == resource.data.callerId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'answeredAt',
            'startedAt',
            'endedAt',
            'endedBy',
            'endReason',
            'updatedAt'
          ]);
        allow delete: if false;

        match /participants/{uid} {
          allow read: if isThreadParticipantByParent(threadId);
          allow create, update: if isThreadParticipantByParent(threadId)
            && request.auth.uid == uid
            && request.resource.data.uid == uid;
          allow delete: if isThreadParticipantByParent(threadId)
            && request.auth.uid == uid;
        }

        match /offers/{uid} {
          allow read: if isThreadParticipantByParent(threadId);
          allow create, update: if isThreadParticipantByParent(threadId)
            && request.auth.uid == uid
            && request.resource.data.type in ['offer']
            && request.resource.data.sdp is string;
          allow delete: if false;
        }

        match /answers/{uid} {
          allow read: if isThreadParticipantByParent(threadId);
          allow create, update: if isThreadParticipantByParent(threadId)
            && request.auth.uid == uid
            && request.resource.data.type in ['answer']
            && request.resource.data.sdp is string;
          allow delete: if false;
        }

        match /candidates/{uid}/items/{candidateId} {
          allow read: if isThreadParticipantByParent(threadId);
          allow create: if isThreadParticipantByParent(threadId)
            && request.auth.uid == uid
            && request.resource.data.candidate is string;
          allow update: if false;
          allow delete: if isThreadParticipantByParent(threadId)
            && request.auth.uid == uid;
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
