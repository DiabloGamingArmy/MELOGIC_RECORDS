rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isUsernameDocIdValid(usernameLower) {
      return request.resource.data.usernameLower == usernameLower
        && request.resource.data.username == usernameLower;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /profiles/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && request.resource.data.uid == uid;
      allow delete: if isOwner(uid);
    }

    match /usernameClaims/{usernameLower} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && isUsernameDocIdValid(usernameLower);
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && isUsernameDocIdValid(usernameLower);
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.artistId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.artistId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
