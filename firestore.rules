rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function threadDoc(threadId) {
      return get(/databases/$(database)/documents/threads/$(threadId));
    }

    function threadExists(threadId) {
      return threadDoc(threadId).exists();
    }

    function isThreadOwner(threadId) {
      return isThreadParticipant(threadId) && threadDoc(threadId).data.createdBy == request.auth.uid;
    }

    function isThreadParticipant(threadId) {
      return signedIn()
        && threadExists(threadId)
        && request.auth.uid in threadDoc(threadId).data.participantIds;
    }

    function participantSelfUpdateIsSafe(uid) {
      return request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'lastReadAt',
          'lastDeliveredAt',
          'typingUpdatedAt',
          'muted',
          'archived',
          'updatedAt',
          'displayName',
          'username',
          'avatarURL',
          'photoURL'
        ]);
    }

    function participantSafeThreadUpdate(threadId) {
      return isThreadParticipant(threadId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'updatedAt',
          'lastMessageAt',
          'lastMessageText',
          'lastMessageSenderId',
          'lastMessageType'
        ]);
    }

    function isUsernameDocIdValid(usernameLower) {
      return request.resource.data.usernameLower == usernameLower
        && request.resource.data.username == usernameLower;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /inboxThreads/{threadId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /profiles/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && request.resource.data.uid == uid;
      allow delete: if isOwner(uid);
    }

    match /usernameClaims/{usernameLower} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && isUsernameDocIdValid(usernameLower);
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && isUsernameDocIdValid(usernameLower);
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.artistId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.artistId == request.auth.uid;
    }

    match /threads/{threadId} {
      allow read: if isThreadParticipant(threadId);
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if isThreadOwner(threadId) || participantSafeThreadUpdate(threadId);
      allow delete: if false;

      match /participants/{uid} {
        allow read: if isThreadParticipant(threadId);
        allow create: if isThreadOwner(threadId)
          || (signedIn() && request.auth.uid == uid && isThreadParticipant(threadId));
        allow update: if isThreadOwner(threadId)
          || (signedIn() && isThreadParticipant(threadId) && participantSelfUpdateIsSafe(uid));
        allow delete: if isThreadOwner(threadId);
      }

      match /messages/{messageId} {
        allow read: if isThreadParticipant(threadId);
        allow create: if isThreadParticipant(threadId)
          && request.resource.data.senderId == request.auth.uid;
        allow update: if false;
        allow delete: if false;
      }

      match /typing/{uid} {
        allow read: if isThreadParticipant(threadId);
        allow create, update, delete: if signedIn()
          && isThreadParticipant(threadId)
          && request.auth.uid == uid;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
