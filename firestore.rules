rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminClaim() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwnerAdminRole() {
      return isAdminClaim() && request.auth.token.adminRole in ['owner', 'admin'];
    }

    function hasProductReviewClaim() {
      return isOwnerAdminRole() || (isAdminClaim() && request.auth.token.productReview == true);
    }

    function hasAuditReadClaim() {
      return isOwnerAdminRole() || (isAdminClaim() && request.auth.token.auditRead == true);
    }

    function hasRoleManageClaim() {
      return isAdminClaim() && request.auth.token.roleManage == true;
    }

    function hasUserModerateClaim() {
      return isOwnerAdminRole() || (isAdminClaim() && request.auth.token.userModerate == true);
    }

    function hasOrderSupportClaim() {
      return isOwnerAdminRole() || (isAdminClaim() && request.auth.token.orderSupport == true);
    }

    function hasEmailSendClaim() {
      return isOwnerAdminRole() || (isAdminClaim() && request.auth.token.emailSend == true);
    }

    function canReadReportsClaim() {
      return hasUserModerateClaim() || hasProductReviewClaim() || hasOrderSupportClaim();
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userServerControlledKeys() {
      return [
        'accountStatus',
        'suspended',
        'suspendedAt',
        'suspendedBy',
        'unsuspendedAt',
        'unsuspendedBy',
        'suspensionReason',
        'suspensionNote',
        'suspensionDuration',
        'suspensionUntil',
        'unsuspensionReason'
      ];
    }

    function userWriteAvoidsServerControlledFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(userServerControlledKeys());
    }

    function profileServerControlledKeys() {
      return [
        'accountStatus',
        'suspended',
        'publicBadges',
        'followerCount',
        'followersCount',
        'followingCount'
      ];
    }

    function threadPath(threadId) {
      return /databases/$(database)/documents/threads/$(threadId);
    }

    function threadExists(threadId) {
      return exists(threadPath(threadId));
    }

    function threadData(threadId) {
      return get(threadPath(threadId)).data;
    }

    // Use this ONLY for thread subcollections.
    function isThreadParticipant(threadId) {
      return signedIn()
        && threadExists(threadId)
        && threadData(threadId).participantIds is list
        && request.auth.uid in threadData(threadId).participantIds;
    }

    function isThreadOwner(threadId) {
      return isThreadParticipant(threadId)
        && threadData(threadId).createdBy == request.auth.uid;
    }

    // Use this for /threads/{threadId} parent document get/list/update rules.
    function isThreadParticipantResource() {
      return signedIn()
        && resource.data.participantIds is list
        && request.auth.uid in resource.data.participantIds;
    }

    function isThreadOwnerResource() {
      return isThreadParticipantResource()
        && resource.data.createdBy == request.auth.uid;
    }

    function isThreadParticipantCreate() {
      return signedIn()
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds;
    }

    function supportThreadPath(threadId) {
      return /databases/$(database)/documents/supportThreads/$(threadId);
    }

    function supportThreadExists(threadId) {
      return exists(supportThreadPath(threadId));
    }

    function supportThreadData(threadId) {
      return get(supportThreadPath(threadId)).data;
    }

    function canReadSupportThreadResource() {
      return signedIn()
        && (
          hasOrderSupportClaim()
          || hasEmailSendClaim()
          || resource.data.requesterUid == request.auth.uid
          || (
            resource.data.participantUids is list
            && request.auth.uid in resource.data.participantUids
          )
        );
    }

    function canReadSupportThreadById(threadId) {
      let thread = supportThreadData(threadId);
      return signedIn()
        && supportThreadExists(threadId)
        && (
          hasOrderSupportClaim()
          || hasEmailSendClaim()
          || thread.requesterUid == request.auth.uid
          || (
            thread.participantUids is list
            && request.auth.uid in thread.participantUids
          )
        );
    }

    function participantSelfUpdateIsSafe(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastReadAt',
          'lastDeliveredAt',
          'typingUpdatedAt',
          'muted',
          'archived',
          'updatedAt',
          'displayName',
          'username',
          'avatarURL',
          'photoURL'
        ]);
    }

    function participantSafeThreadUpdateResource() {
      return isThreadParticipantResource()
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'updatedAt',
          'lastMessageAt',
          'lastMessageText',
          'lastMessageSenderId',
          'lastMessageType',
          'lastMessageAttachmentCount',
          'dmBlockState'
        ])
        && dmBlockStateUpdateIsSafe();
    }

    function dmBlockStateUpdateIsSafe() {
      let changed = request.resource.data.diff(resource.data).affectedKeys().hasAny(['dmBlockState']);
      let participantIds = resource.data.participantIds;
      let otherParticipant = participantIds[0] == request.auth.uid ? participantIds[1] : participantIds[0];
      return !changed || (
        resource.data.type == 'dm'
        && participantIds is list
        && participantIds.size() == 2
        && request.auth.uid in participantIds
        && (
          (
            request.resource.data.dmBlockState is map
            && request.resource.data.dmBlockState.blockedBy == request.auth.uid
            && request.resource.data.dmBlockState.blockedUid == otherParticipant
          )
          || (
            request.resource.data.dmBlockState == null
            && resource.data.dmBlockState is map
            && resource.data.dmBlockState.blockedBy == request.auth.uid
          )
        )
      );
    }

    function validMessageCreate() {
      let body = request.resource.data.body;
      let attachments = request.resource.data.attachments;
      let hasBody = body is string && body.size() > 0;
      let hasAttachments = attachments is list && attachments.size() > 0;
      return request.resource.data.keys().hasOnly([
          'senderId',
          'body',
          'type',
          'attachments',
          'createdAt',
          'updatedAt',
          'deleted',
          'edited',
          'replyTo',
          'clientMessageId'
        ])
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 1200
        && request.resource.data.type in ['text', 'image', 'video', 'audio', 'file', 'attachment']
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() <= 10
        && request.resource.data.deleted == false
        && request.resource.data.edited == false
        && (!('replyTo' in request.resource.data) || request.resource.data.replyTo is map)
        && (!('clientMessageId' in request.resource.data) || (
          request.resource.data.clientMessageId is string
          && request.resource.data.clientMessageId.size() <= 80
        ))
        && (hasBody || hasAttachments);
    }

    function dmAllowsMessageCreate(threadId) {
      let thread = threadData(threadId);
      return !(thread.type == 'dm' && thread.dmBlockState is map);
    }

    function validMessageEdit() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'body',
          'edited',
          'editedAt',
          'updatedAt'
        ])
        && resource.data.senderId == request.auth.uid
        && !resource.data.deleted
        && (!(resource.data.attachments is list) || resource.data.attachments.size() == 0)
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1200
        && request.resource.data.edited == true;
    }

    function validMessageDeleteForEveryone(threadId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'body',
          'attachments',
          'deleted',
          'deletedAt',
          'deletedBy',
          'updatedAt'
        ])
        && (
          resource.data.senderId == request.auth.uid
          || threadData(threadId).createdBy == request.auth.uid
        )
        && request.resource.data.deleted == true
        && request.resource.data.deletedBy == request.auth.uid
        && request.resource.data.body == ''
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() == 0;
    }

    function isUsernameDocIdValid(usernameLower) {
      return request.resource.data.usernameLower == usernameLower
        && request.resource.data.username == usernameLower;
    }

    function productAllowedKeys() {
      return request.resource.data.keys().hasOnly([
        'id',
        'slug',
        'status',
        'visibility',

        'title',
        'shortDescription',
        'description',
        'version',
        'usageLicense',
        'productType',
        'productKind',
        'previewMode',
        'distributionMode',

        'categories',
        'genres',
        'tags',
        'categoryKeys',
        'genreKeys',
        'tagKeys',
        'searchKeywords',

        'artistId',
        'artistName',
        'artistDisplayName',
        'artistUsername',
        'artistProfilePath',
        'artistAvatarURL',
        'artistPhotoURL',
        'artistNameLower',
        'artistUsernameLower',

        'contributorIds',
        'contributorNames',
        'contributorCount',
        'pendingContributorIds',
        'contributorRequestCount',
        'sellerAgreement',
        'sellerAgreementAccepted',
        'sellerAgreementVersion',

        'coverPath',
        'thumbnailPath',
        'coverURL',
        'thumbnailURL',
        'galleryPaths',
        'previewAudioPaths',
        'previewVideoPaths',
        'downloadPath',
        'deliverableFiles',
        'licensePath',
        'assetSummary',
        'primaryPreviewPath',
        'primaryPreviewType',
        'primaryPreviewDuration',
        'primaryDownloadPath',
        'primaryDownloadBytes',
        'previewAssignment',

        'price',
        'priceLabel',
        'priceCents',
        'payoutTargetCents',
        'currency',
        'isFree',
        'saleEnabled',
        'storefrontVisible',

        'dawCompatibility',
        'formatKeys',
        'formatNotes',
        'compatibilityNotes',
        'includedFiles',

        'releasedAt',
        'createdAt',
        'updatedAt',

        'publishedAt',
        'moderationStatus',
        'moderationSummary',
        'moderationReasons',
        'moderationRiskLevel',
        'moderationAIConfigured',
        'moderationAIAttempted',
        'moderationAISucceeded',
        'moderationAIEnabled',
        'moderationAIModel',
        'moderationAIError',
        'moderationAIErrorCode',
        'moderationAIErrorCategory',
        'moderationAICompletedAt',
        'moderationAIFailedAt',
        'reviewRequestedAt',
        'reviewRequestedBy',
        'reviewJobStatus',
        'reviewedAt',
        'reviewedBy',

        'likeCount',
        'dislikeCount',
        'saveCount',
        'downloadCount',
        'commentCount',
        'shareCount',
        'followCount',
        'counts',

        'featured',
        'promoted',
        'salesCount',
        'revenue',
        'entitlementCount'
      ]);
    }

    function productStatusIsCreatorWritable() {
      return request.resource.data.status in [
        'draft',
        'review_pending',
        'pending_ai_review',
        'needs_changes',
        'rejected',
        'archived'
      ];
    }

    function productFieldShapesAreValid() {
      return request.resource.data.id is string
        && request.resource.data.id.size() > 0
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.artistId is string
        && request.resource.data.artistId == request.auth.uid
        && productStatusIsCreatorWritable()
        && request.resource.data.visibility in [
          'public',
          'private',
          'unlisted'
        ]
        && (!('slug' in request.resource.data) || request.resource.data.slug is string)
        && (!('shortDescription' in request.resource.data) || (
          request.resource.data.shortDescription is string
          && request.resource.data.shortDescription.size() <= 500
        ))
        && (!('description' in request.resource.data) || (
          request.resource.data.description is string
          && request.resource.data.description.size() <= 20000
        ))
        && (!('version' in request.resource.data) || request.resource.data.version is string)
        && (!('usageLicense' in request.resource.data) || request.resource.data.usageLicense is string)
        && (!('productType' in request.resource.data) || request.resource.data.productType is string)
        && (!('productKind' in request.resource.data) || request.resource.data.productKind is string)
        && (!('previewMode' in request.resource.data) || request.resource.data.previewMode is string)
        && (!('distributionMode' in request.resource.data) || request.resource.data.distributionMode is string)
        && (!('price' in request.resource.data) || request.resource.data.price is string)
        && (!('priceLabel' in request.resource.data) || request.resource.data.priceLabel is string)
        && (!('priceCents' in request.resource.data) || (
          request.resource.data.priceCents is number
          && request.resource.data.priceCents >= 0
          && request.resource.data.priceCents <= 10000000
        ))
        && (!('payoutTargetCents' in request.resource.data) || (
          request.resource.data.payoutTargetCents is number
          && request.resource.data.payoutTargetCents >= 0
          && request.resource.data.payoutTargetCents <= 10000000
        ))
        && (!('currency' in request.resource.data) || request.resource.data.currency in ['USD', 'EUR', 'GBP'])
        && (!('isFree' in request.resource.data) || request.resource.data.isFree is bool)
        && (!('saleEnabled' in request.resource.data) || request.resource.data.saleEnabled is bool)
        && (!('storefrontVisible' in request.resource.data) || request.resource.data.storefrontVisible is bool)
        && (!('tags' in request.resource.data) || (
          request.resource.data.tags is list
          && request.resource.data.tags.size() <= 50
        ))
        && (!('categories' in request.resource.data) || (
          request.resource.data.categories is list
          && request.resource.data.categories.size() <= 20
        ))
        && (!('genres' in request.resource.data) || (
          request.resource.data.genres is list
          && request.resource.data.genres.size() <= 20
        ))
        && (!('searchKeywords' in request.resource.data) || (
          request.resource.data.searchKeywords is list
          && request.resource.data.searchKeywords.size() <= 120
        ))
        && (!('categoryKeys' in request.resource.data) || request.resource.data.categoryKeys is list)
        && (!('genreKeys' in request.resource.data) || request.resource.data.genreKeys is list)
        && (!('tagKeys' in request.resource.data) || request.resource.data.tagKeys is list)
        && (!('dawCompatibility' in request.resource.data) || request.resource.data.dawCompatibility is list)
        && (!('formatKeys' in request.resource.data) || request.resource.data.formatKeys is list)
        && (!('contributorIds' in request.resource.data) || (
          request.resource.data.contributorIds is list
          && request.resource.data.contributorIds.size() <= 25
        ))
        && (!('contributorNames' in request.resource.data) || (
          request.resource.data.contributorNames is list
          && request.resource.data.contributorNames.size() <= 25
        ))
        && (!('contributorCount' in request.resource.data) || (
          request.resource.data.contributorCount is number
          && request.resource.data.contributorCount >= 0
          && request.resource.data.contributorCount <= 25
        ))
        && (!('pendingContributorIds' in request.resource.data) || (
          request.resource.data.pendingContributorIds is list
          && request.resource.data.pendingContributorIds.size() <= 25
        ))
        && (!('contributorRequestCount' in request.resource.data) || (
          request.resource.data.contributorRequestCount is number
          && request.resource.data.contributorRequestCount >= 0
          && request.resource.data.contributorRequestCount <= 25
        ))
        && (!('sellerAgreement' in request.resource.data) || request.resource.data.sellerAgreement is map)
        && (!('sellerAgreementAccepted' in request.resource.data) || request.resource.data.sellerAgreementAccepted is bool)
        && (!('sellerAgreementVersion' in request.resource.data) || request.resource.data.sellerAgreementVersion is string)
        && (!('coverPath' in request.resource.data) || request.resource.data.coverPath is string)
        && (!('thumbnailPath' in request.resource.data) || request.resource.data.thumbnailPath is string)
        && (!('coverURL' in request.resource.data) || request.resource.data.coverURL is string)
        && (!('thumbnailURL' in request.resource.data) || request.resource.data.thumbnailURL is string)
        && (!('galleryPaths' in request.resource.data) || (
          request.resource.data.galleryPaths is list
          && request.resource.data.galleryPaths.size() <= 24
        ))
        && (!('previewAudioPaths' in request.resource.data) || (
          request.resource.data.previewAudioPaths is list
          && request.resource.data.previewAudioPaths.size() <= 12
        ))
        && (!('previewVideoPaths' in request.resource.data) || (
          request.resource.data.previewVideoPaths is list
          && request.resource.data.previewVideoPaths.size() <= 8
        ))
        && (!('downloadPath' in request.resource.data) || request.resource.data.downloadPath is string)
        && (!('deliverableFiles' in request.resource.data) || (
          request.resource.data.deliverableFiles is list
          && request.resource.data.deliverableFiles.size() <= 500
        ))
        && (!('licensePath' in request.resource.data) || request.resource.data.licensePath is string)
        && (!('assetSummary' in request.resource.data) || request.resource.data.assetSummary is map)
        && (!('primaryPreviewPath' in request.resource.data) || request.resource.data.primaryPreviewPath is string)
        && (!('primaryPreviewType' in request.resource.data) || request.resource.data.primaryPreviewType is string)
        && (!('primaryPreviewDuration' in request.resource.data) || (
          request.resource.data.primaryPreviewDuration is number
          && request.resource.data.primaryPreviewDuration >= 0
        ))
        && (!('primaryDownloadPath' in request.resource.data) || request.resource.data.primaryDownloadPath is string)
        && (!('primaryDownloadBytes' in request.resource.data) || (
          request.resource.data.primaryDownloadBytes is number
          && request.resource.data.primaryDownloadBytes >= 0
        ))
        && (!('previewAssignment' in request.resource.data) || request.resource.data.previewAssignment is map)
        && (!('formatNotes' in request.resource.data) || (
          request.resource.data.formatNotes is string
          && request.resource.data.formatNotes.size() <= 5000
        ))
        && (!('compatibilityNotes' in request.resource.data) || (
          request.resource.data.compatibilityNotes is string
          && request.resource.data.compatibilityNotes.size() <= 5000
        ))
        && (!('includedFiles' in request.resource.data) || (
          request.resource.data.includedFiles is string
          && request.resource.data.includedFiles.size() <= 10000
        ))
        && (!('moderationRiskLevel' in request.resource.data) || request.resource.data.moderationRiskLevel is string)
        && (!('moderationAIConfigured' in request.resource.data) || request.resource.data.moderationAIConfigured is bool)
        && (!('moderationAIAttempted' in request.resource.data) || request.resource.data.moderationAIAttempted is bool)
        && (!('moderationAISucceeded' in request.resource.data) || request.resource.data.moderationAISucceeded is bool)
        && (!('moderationAIEnabled' in request.resource.data) || request.resource.data.moderationAIEnabled is bool)
        && (!('moderationAIModel' in request.resource.data) || request.resource.data.moderationAIModel is string)
        && (!('moderationAIError' in request.resource.data) || request.resource.data.moderationAIError is string)
        && (!('moderationAIErrorCode' in request.resource.data) || request.resource.data.moderationAIErrorCode is string)
        && (!('moderationAIErrorCategory' in request.resource.data) || request.resource.data.moderationAIErrorCategory is string)
        && (!('reviewRequestedBy' in request.resource.data) || request.resource.data.reviewRequestedBy is string)
        && (!('reviewJobStatus' in request.resource.data) || request.resource.data.reviewJobStatus is string);
    }

    function safeModerationStatusCreate() {
      return !('moderationStatus' in request.resource.data)
        || request.resource.data.moderationStatus == null
        || request.resource.data.moderationStatus == ''
        || request.resource.data.moderationStatus == 'not_submitted'
        || request.resource.data.moderationStatus == 'pending'
        || request.resource.data.moderationStatus == 'queued';
    }

    function isProductReviewSubmission() {
      return resource.data.status in [
          'draft',
          'needs_changes',
          'rejected',
          'review_pending',
          'pending_ai_review'
        ]
        && request.resource.data.status in [
          'review_pending',
          'pending_ai_review'
        ];
    }

    function safeModerationStatusUpdate() {
      return !('moderationStatus' in request.resource.data)
        || (
          'moderationStatus' in resource.data
          && request.resource.data.moderationStatus == resource.data.moderationStatus
        )
        || (
          !('moderationStatus' in resource.data)
          && safeModerationStatusCreate()
        )
        || (
          isProductReviewSubmission()
          && (
            request.resource.data.moderationStatus == 'pending'
            || request.resource.data.moderationStatus == 'queued'
            || request.resource.data.moderationStatus == null
            || request.resource.data.moderationStatus == ''
          )
        );
    }

    function productServerFieldsSafeOnUpdate() {
      return safeModerationStatusUpdate()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'moderationSummary',
          'moderationReasons',
          'moderationRiskLevel',
          'moderationAIConfigured',
          'moderationAIAttempted',
          'moderationAISucceeded',
          'moderationAIEnabled',
          'moderationAIModel',
          'moderationAIError',
          'moderationAIErrorCode',
          'moderationAIErrorCategory',
          'moderationAICompletedAt',
          'moderationAIFailedAt',
          'reviewRequestedAt',
          'reviewRequestedBy',
          'reviewJobStatus',
          'reviewedAt',
          'reviewedBy',
          'publishedAt',
          'likeCount',
          'dislikeCount',
          'saveCount',
          'downloadCount',
          'commentCount',
          'shareCount',
          'followCount',
          'counts',
          'featured',
          'promoted',
          'salesCount',
          'revenue',
          'entitlementCount'
        ]);
    }

    function creatorIdentityIsStable() {
      return resource.data.artistId == request.auth.uid
        && request.resource.data.artistId == resource.data.artistId
        && request.resource.data.artistProfilePath == resource.data.artistProfilePath;
    }

    function productCreateIsAllowed(productId) {
      // Product shell creation needs to be permissive enough for the editor's
      // first draft write, but it must never let a client publish directly.
      // Keep update/review/publish rules stricter after the shell exists.
      return signedIn()
        && request.resource.data.id is string
        && request.resource.data.id == productId
        && request.resource.data.artistId is string
        && request.resource.data.artistId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.status in ['draft', 'review_pending', 'pending_ai_review']
        && request.resource.data.visibility in ['private', 'unlisted']
        && (!('slug' in request.resource.data) || request.resource.data.slug is string)
        && (!('shortDescription' in request.resource.data) || (
          request.resource.data.shortDescription is string
          && request.resource.data.shortDescription.size() <= 500
        ))
        && (!('description' in request.resource.data) || (
          request.resource.data.description is string
          && request.resource.data.description.size() <= 20000
        ))
        && (!('artistName' in request.resource.data) || request.resource.data.artistName is string)
        && (!('artistDisplayName' in request.resource.data) || request.resource.data.artistDisplayName is string)
        && (!('artistUsername' in request.resource.data) || request.resource.data.artistUsername is string)
        && (!('artistProfilePath' in request.resource.data) || request.resource.data.artistProfilePath is string)
        && (!('artistAvatarURL' in request.resource.data) || request.resource.data.artistAvatarURL is string)
        && (!('artistPhotoURL' in request.resource.data) || request.resource.data.artistPhotoURL is string)
        && (!('productType' in request.resource.data) || request.resource.data.productType is string)
        && (!('currency' in request.resource.data) || request.resource.data.currency in ['USD', 'EUR', 'GBP'])
        && (!('price' in request.resource.data) || request.resource.data.price is string)
        && (!('priceLabel' in request.resource.data) || request.resource.data.priceLabel is string)
        && (!('price' in request.resource.data) || request.resource.data.price is string)
        && (!('priceLabel' in request.resource.data) || request.resource.data.priceLabel is string)
        && (!('priceCents' in request.resource.data) || (
          request.resource.data.priceCents is number
          && request.resource.data.priceCents >= 0
          && request.resource.data.priceCents <= 10000000
        ))
        && (!('payoutTargetCents' in request.resource.data) || (
          request.resource.data.payoutTargetCents is number
          && request.resource.data.payoutTargetCents >= 0
          && request.resource.data.payoutTargetCents <= 10000000
        ))
        && (!('isFree' in request.resource.data) || request.resource.data.isFree is bool);
    }

    function productUpdateIsAllowed() {
      return signedIn()
        && resource.data.artistId == request.auth.uid
        && creatorIdentityIsStable()
        && productAllowedKeys()
        && productFieldShapesAreValid()
        && productServerFieldsSafeOnUpdate()
        && request.resource.data.status != 'published'
        && request.resource.data.visibility != 'public'
        && (
          resource.data.status != 'published'
          || request.resource.data.status in ['draft', 'review_pending', 'pending_ai_review', 'needs_changes']
        );
    }

    function productIsPublicById(productId) {
      return get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'
        && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public';
    }

    function productOwnerById(productId) {
      return signedIn()
        && get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid;
    }

    function productEntitledById(productId) {
      return signedIn()
        && (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/entitlements/$(productId))
          || exists(/databases/$(database)/documents/users/$(request.auth.uid)/libraryItems/$(productId))
        );
    }

    function canReadProductById(productId) {
      return productIsPublicById(productId)
        || productOwnerById(productId)
        || productEntitledById(productId);
    }

    function canReadProductResource(productId) {
      return (resource.data.status == 'published' && resource.data.visibility == 'public')
        || (signedIn() && resource.data.artistId == request.auth.uid)
        || productEntitledById(productId);
    }




    function isStudioOwnerResource() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isStudioCollaboratorResource() {
      return signedIn()
        && resource.data.collaboratorIds is list
        && request.auth.uid in resource.data.collaboratorIds;
    }

    function studioTypeValid(value) {
      return value in ['song', 'beat', 'vocal', 'podcast', 'blank'];
    }

    function studioProjectCreateIsValid() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'title','ownerId','collaboratorIds','bpm','key','timeSignature','type','visibility','createdAt','updatedAt','lastOpenedAt','version','tracks','timeline','mixer','collaboration','settings','globalTracks','editorState'
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.collaboratorIds is list
        && request.resource.data.collaboratorIds.size() == 0
        && request.resource.data.visibility == 'private'
        && request.resource.data.version == 1
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 120
        && request.resource.data.bpm is number
        && request.resource.data.bpm >= 40
        && request.resource.data.bpm <= 240
        && request.resource.data.key is string
        && request.resource.data.key.size() >= 1
        && request.resource.data.key.size() <= 40
        && request.resource.data.type is string
        && studioTypeValid(request.resource.data.type)
        && (!('timeSignature' in request.resource.data) || request.resource.data.timeSignature is string)
        && (!('tracks' in request.resource.data) || request.resource.data.tracks is list)
        && (!('timeline' in request.resource.data) || request.resource.data.timeline is map)
        && (!('mixer' in request.resource.data) || request.resource.data.mixer is map)
        && (!('collaboration' in request.resource.data) || request.resource.data.collaboration is map)
        && (!('settings' in request.resource.data) || request.resource.data.settings is map)
        && (!('globalTracks' in request.resource.data) || request.resource.data.globalTracks is map)
        && (!('editorState' in request.resource.data) || request.resource.data.editorState is map);
    }

    function studioProjectUpdateIsValid() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'title','ownerId','collaboratorIds','bpm','key','timeSignature','type','visibility','createdAt','updatedAt','lastOpenedAt','version','tracks','timeline','mixer','collaboration','settings','globalTracks','editorState'
        ])
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.collaboratorIds == resource.data.collaboratorIds
        && request.resource.data.visibility == 'private'
        && request.resource.data.version == 1
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 120
        && request.resource.data.bpm is number
        && request.resource.data.bpm >= 40
        && request.resource.data.bpm <= 240
        && request.resource.data.key is string
        && request.resource.data.key.size() >= 1
        && request.resource.data.key.size() <= 40
        && request.resource.data.type is string
        && studioTypeValid(request.resource.data.type)
        && (!('timeSignature' in request.resource.data) || request.resource.data.timeSignature is string)
        && (!('tracks' in request.resource.data) || request.resource.data.tracks is list)
        && (!('timeline' in request.resource.data) || request.resource.data.timeline is map)
        && (!('mixer' in request.resource.data) || request.resource.data.mixer is map)
        && (!('collaboration' in request.resource.data) || request.resource.data.collaboration is map)
        && (!('settings' in request.resource.data) || request.resource.data.settings is map)
        && (!('globalTracks' in request.resource.data) || request.resource.data.globalTracks is map)
        && (!('editorState' in request.resource.data) || request.resource.data.editorState is map);
    }

    function isStageOwnerResource() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isStageCollaboratorResource() {
      return signedIn()
        && resource.data.collaboratorIds is list
        && request.auth.uid in resource.data.collaboratorIds;
    }

    function isPublicStageProjectResource() {
      return resource.data.visibility == 'public';
    }

    function stageTypeValid(value) {
      return value in [
        'Blank Stage',
        'Small Club',
        'Band Performance',
        'DJ / EDM Stage',
        'Church Service',
        'Festival',
        'Festival Stage',
        'Worship/Church',
        'Livestream Room',
        'Livestream Setup',
        'School Auditorium'
      ];
    }

    function stageUnitValid(value) {
      return value in ['ft', 'm'];
    }

    function stageDocumentKeysValid(data) {
      return data.keys().hasOnly([
        'title','ownerId','collaboratorIds','visibility','type','stageType','stage','stageDimensions',
        'coordinateSystem','objects','fixtures','audioInputs','rigging','video','power','layers',
        'measurements','annotations','venue','notes','exportSettings',
        'plan','version','createdAt','updatedAt','lastOpenedAt','editorState'
      ]);
    }

    function legacyStageValid(stage) {
      return stage is map
        && stage.keys().hasOnly(['width', 'depth', 'height', 'deckHeight', 'unit'])
        && stage.width is number
        && stage.width > 0
        && stage.width <= 1000
        && stage.depth is number
        && stage.depth > 0
        && stage.depth <= 1000
        && (!('height' in stage) || (stage.height is number && stage.height >= 0 && stage.height <= 100))
        && (!('deckHeight' in stage) || (stage.deckHeight is number && stage.deckHeight >= 0 && stage.deckHeight <= 100))
        && stage.unit is string
        && stageUnitValid(stage.unit);
    }

    function stageDimensionsValid(dimensions) {
      return dimensions is map
        && dimensions.keys().hasOnly(['width', 'depth', 'height', 'deckHeight', 'unit'])
        && dimensions.width is number
        && dimensions.width > 0
        && dimensions.width <= 1000
        && dimensions.depth is number
        && dimensions.depth > 0
        && dimensions.depth <= 1000
        && (!('height' in dimensions) || (dimensions.height is number && dimensions.height >= 0 && dimensions.height <= 100))
        && (!('deckHeight' in dimensions) || (dimensions.deckHeight is number && dimensions.deckHeight >= 0 && dimensions.deckHeight <= 100))
        && dimensions.unit is string
        && stageUnitValid(dimensions.unit);
    }

    function stageProjectDataValid(data) {
      return stageDocumentKeysValid(data)
        && data.visibility == 'private'
        && data.type == 'stage-plan'
        && data.version == 1
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 120
        && data.stageType is string
        && stageTypeValid(data.stageType)
        && legacyStageValid(data.stage)
        && data.objects is list
        && data.objects.size() <= 1000
        && data.notes is string
        && data.notes.size() <= 20000
        && (!('stageDimensions' in data) || stageDimensionsValid(data.stageDimensions))
        && (!('coordinateSystem' in data) || data.coordinateSystem is map)
        && (!('fixtures' in data) || (data.fixtures is list && data.fixtures.size() <= 1000))
        && (!('audioInputs' in data) || (data.audioInputs is list && data.audioInputs.size() <= 500))
        && (!('rigging' in data) || (data.rigging is list && data.rigging.size() <= 500))
        && (!('video' in data) || (data.video is list && data.video.size() <= 500))
        && (!('power' in data) || (data.power is list && data.power.size() <= 250))
        && (!('layers' in data) || (data.layers is list && data.layers.size() <= 50))
        && (!('measurements' in data) || (data.measurements is list && data.measurements.size() <= 500))
        && (!('annotations' in data) || (data.annotations is list && data.annotations.size() <= 500))
        && (!('venue' in data) || data.venue is map)
        && (!('exportSettings' in data) || data.exportSettings is map)
        && (!('plan' in data) || data.plan is map)
        && (!('editorState' in data) || data.editorState is map);
    }

    function stageProjectCreateIsValid() {
      return signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.collaboratorIds is list
        && request.resource.data.collaboratorIds.size() == 0
        && stageProjectDataValid(request.resource.data);
    }

    function stageProjectUpdateIsValid() {
      return signedIn()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.collaboratorIds == resource.data.collaboratorIds
        && stageProjectDataValid(request.resource.data);
    }
    match /presence/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == userId;
      allow delete: if isOwner(userId);

      match /sessions/{sessionId} {
        allow read: if signedIn();
        allow create, update: if isOwner(userId)
          && request.resource.data.uid == userId
          && request.resource.data.sessionId == sessionId;
        allow delete: if isOwner(userId);
      }
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && !request.resource.data.keys().hasAny(userServerControlledKeys());
      allow update: if isOwner(uid)
        && userWriteAvoidsServerControlledFields();
      allow delete: if false;

      match /entitlements/{productId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /libraryItems/{itemId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /orders/{orderId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /commerceSummary/{summaryId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /creatorCompliance/{complianceId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /billing/{billingId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /earningsSummary/{summaryId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /sales/{saleId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /adminNotes/{noteId} {
        allow read, write: if false;
      }

      match /permissions/{permissionId} {
        allow read: if permissionId == 'current'
          && (isOwner(uid) || hasUserModerateClaim() || hasRoleManageClaim());
        allow write: if false;
      }

      match /savedProducts/{productId} {
        allow read: if isOwner(uid);

        allow create, update: if isOwner(uid)
          && request.resource.data.productId == productId;

        allow delete: if isOwner(uid);
      }

      match /focusedCommunities/{communityId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /followers/{followerUid} {
        allow read: if isOwner(uid) || (signedIn() && request.auth.uid == followerUid);
        allow write: if false;
      }

      match /following/{targetUid} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /dismissedSuggestions/{suggestedUid} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /clientCapabilities/{sessionId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly([
            'uid', 'sessionId', 'platform', 'supportsContactPicker',
            'supportsFilePicker', 'supportsShare', 'supportsPush',
            'browserName', 'osName', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'uid', 'sessionId', 'platform', 'supportsContactPicker',
            'supportsFilePicker', 'supportsShare', 'supportsPush',
            'browserName', 'osName', 'updatedAt'
          ])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.sessionId == sessionId
          && sessionId.size() >= 1
          && sessionId.size() <= 80
          && request.resource.data.platform in [
            'desktop-web', 'mobile-web', 'pwa', 'native-wrapper', 'unknown'
          ]
          && request.resource.data.supportsContactPicker is bool
          && request.resource.data.supportsFilePicker is bool
          && request.resource.data.supportsShare is bool
          && request.resource.data.supportsPush is bool
          && request.resource.data.browserName is string
          && request.resource.data.browserName.size() <= 40
          && request.resource.data.osName is string
          && request.resource.data.osName.size() <= 40
          && request.resource.data.updatedAt is timestamp;
        allow delete: if isOwner(uid);
      }

      match /studioProjectIndex/{projectId} {
        allow read: if isOwner(uid);

        allow create, update: if isOwner(uid)
          && request.resource.data.projectId == projectId
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.role in ['owner', 'collaborator']
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 120;

        allow delete: if isOwner(uid);
      }

      match /stageProjectIndex/{projectId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly([
            'projectId','title','ownerId','visibility','type','stageType','updatedAt','lastOpenedAt','createdAt'
          ])
          && request.resource.data.projectId == projectId
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 120
          && request.resource.data.visibility == 'private'
          && request.resource.data.type == 'stage-plan'
          && request.resource.data.stageType is string
          && stageTypeValid(request.resource.data.stageType);
        allow delete: if isOwner(uid);
      }

      match /agreementAcceptances/{agreementKey} {
        allow read, write: if isOwner(uid);
      }

      match /signedForms/{formKey} {
  allow read: if isOwner(uid);

  allow create, update: if isOwner(uid)
    && (
      !('signedBy' in request.resource.data)
      || request.resource.data.signedBy == uid
      || request.resource.data.signedBy == request.auth.uid
    )
    && (
      !('formKey' in request.resource.data)
      || request.resource.data.formKey == formKey
    );

  allow delete: if false;
}

      match /inboxThreads/{threadId} {
        allow read, write: if isOwner(uid);
      }

      match /inboxThreadPrefs/{threadId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['threadId', 'pinned', 'pinnedAt', 'updatedAt'])
          && request.resource.data.keys().hasAll(['threadId', 'pinned', 'updatedAt'])
          && request.resource.data.threadId == threadId
          && request.resource.data.pinned is bool
          && (!('pinnedAt' in request.resource.data) || request.resource.data.pinnedAt is timestamp || request.resource.data.pinnedAt == null);
        allow delete: if isOwner(uid);
      }

      match /blockedUsers/{targetUid} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /systemNotifications/{notificationId} {
        allow read: if isOwner(uid);
        allow create, delete: if false;
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt', 'hiddenAt'])
          && (!('readAt' in request.resource.data)
            || request.resource.data.readAt is timestamp
            || request.resource.data.readAt == null)
          && (!('hiddenAt' in request.resource.data)
            || request.resource.data.hiddenAt is timestamp
            || request.resource.data.hiddenAt == null);
      }

      match /accountEvents/{eventId} {
        allow read: if isOwner(uid);
        allow create, delete: if false;
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt', 'hiddenAt'])
          && (!('readAt' in request.resource.data)
            || request.resource.data.readAt is timestamp
            || request.resource.data.readAt == null)
          && (!('hiddenAt' in request.resource.data)
            || request.resource.data.hiddenAt is timestamp
            || request.resource.data.hiddenAt == null);
      }

      match /securityDevices/{deviceId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /inboxPins/{pinId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly([
            'pinId', 'type', 'targetId', 'title', 'subtitle', 'sourceCategory',
            'targetPath', 'metadata', 'pinnedAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'pinId', 'type', 'targetId', 'title', 'sourceCategory', 'pinnedAt', 'updatedAt'
          ])
          && request.resource.data.pinId == pinId
          && request.resource.data.type is string
          && request.resource.data.type in ['thread', 'systemNotification', 'accountEvent']
          && request.resource.data.targetId is string
          && request.resource.data.targetId.size() >= 1
          && request.resource.data.targetId.size() <= 180
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 180
          && (!('subtitle' in request.resource.data) || request.resource.data.subtitle is string)
          && (!('targetPath' in request.resource.data) || request.resource.data.targetPath is string)
          && request.resource.data.sourceCategory is string
          && request.resource.data.sourceCategory in ['Messages', 'System', 'Inbox']
          && (!('metadata' in request.resource.data) || request.resource.data.metadata is map);
        allow delete: if isOwner(uid);
      }

      match /hiddenThreadMessages/{threadId}/messages/{messageId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /profiles/{uid} {
      allow read: if true;

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && !request.resource.data.keys().hasAny(profileServerControlledKeys());
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(profileServerControlledKeys());

      allow delete: if isOwner(uid);
    }

    match /usernameClaims/{usernameLower} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && isUsernameDocIdValid(usernameLower);

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && isUsernameDocIdValid(usernameLower);

      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /products/{productId} {
  // Allow the editor to safely check a generated product ID that does not exist yet,
  // without exposing existing private/draft products.
  allow get: if !exists(/databases/$(database)/documents/products/$(productId))
    || canReadProductResource(productId);

  allow list: if canReadProductResource(productId);

  allow create: if productCreateIsAllowed(productId);

  allow update: if productUpdateIsAllowed();

  allow delete: if signedIn()
    && resource.data.artistId == request.auth.uid
    && resource.data.status != 'published';

  match /reviews/{reviewId} {
    allow read: if (get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'
      && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public')
      || (signedIn() && (
        get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid
        || resource.data.uid == request.auth.uid
      ));

    allow create: if signedIn()
      && request.resource.data.uid == request.auth.uid
      && request.resource.data.body is string
      && request.resource.data.body.size() > 0
      && request.resource.data.body.size() <= 5000
      && (!('rating' in request.resource.data) || (request.resource.data.rating is number && request.resource.data.rating >= 0.5 && request.resource.data.rating <= 5));

    allow update: if signedIn() && (
      resource.data.uid == request.auth.uid
      || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'dislikeCount', 'replyCount', 'updatedAt'])
    );
    allow delete: if signedIn() && resource.data.uid == request.auth.uid;

    match /reactions/{reactionId} {
      allow read: if signedIn() && request.auth.uid == reactionId;
      allow create, update: if signedIn()
        && request.auth.uid == reactionId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.reaction in ['like', 'dislike'];
      allow delete: if signedIn() && request.auth.uid == reactionId;
    }

    match /replies/{replyId} {
      allow read: if (get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'
        && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public')
        || signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1200
        && (!('deleted' in request.resource.data) || request.resource.data.deleted == false);

      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }
  }

  match /reactions/{reactionId} {
    allow read: if true;
    allow create, update: if signedIn()
      && reactionId == request.auth.uid
      && request.resource.data.uid == request.auth.uid
      && (!('reaction' in request.resource.data) || request.resource.data.reaction in ['like', 'dislike', null]);
    allow delete: if signedIn() && resource.data.uid == request.auth.uid;
  }

  match /downloads/{downloadId} {
    allow read: if signedIn() && (
      resource.data.userUid == request.auth.uid
      || get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid
    );
    allow write: if false;
  }

  match /comments/{commentId} {
    allow read: if get(/databases/$(database)/documents/products/$(productId)).data.status == 'published'
      && get(/databases/$(database)/documents/products/$(productId)).data.visibility == 'public';

    allow create: if signedIn()
      && request.resource.data.uid == request.auth.uid
      && request.resource.data.body is string
      && request.resource.data.body.size() > 0
      && request.resource.data.body.size() <= 5000;

    allow update, delete: if signedIn()
      && resource.data.uid == request.auth.uid;
  }

  match /files/{fileId} {
    allow read: if canReadProductById(productId);

    allow create, update, delete: if signedIn()
      && productOwnerById(productId)
      && get(/databases/$(database)/documents/products/$(productId)).data.status != 'published';
  }

  match /contributors/{uid} {
    allow read: if signedIn() && (
        get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid
        || request.auth.uid == uid
      );

    allow create, update, delete: if signedIn()
      && get(/databases/$(database)/documents/products/$(productId)).data.artistId == request.auth.uid
      && get(/databases/$(database)/documents/products/$(productId)).data.status != 'published';

    match /productEngagement/{productId} {
      allow read: if true;
      allow write: if false;

      match /users/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if false;
      }
    }

  }
}

    match /productGifts/{giftId} {
      allow read: if signedIn()
        && (resource.data.senderUid == request.auth.uid || resource.data.recipientUid == request.auth.uid);
      allow write: if false;
    }

    match /pendingReview/{reviewArea}/items/{productId} {
  allow read: if signedIn()
    && (
      !('sellerId' in resource.data)
      || resource.data.sellerId == request.auth.uid
    );

  allow create: if signedIn();

  allow update: if signedIn()
    && (
      !('sellerId' in resource.data)
      || resource.data.sellerId == request.auth.uid
      || request.resource.data.sellerId == request.auth.uid
    );

  allow delete: if false;
}

    match /platformSettings/{settingId} {
      allow read: if settingId in [
        'marketplacePricing',
        'marketplaceSellerAgreement'
      ];

      allow write: if settingId in [
        'marketplacePricing',
        'marketplaceSellerAgreement'
      ] && isOwnerAdminRole();
    }

    match /Reports/marketplace/products/reviews/items/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterUid == request.auth.uid;
      allow read: if signedIn() && resource.data.reporterUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /accountCalls/{callId} {
      function isAccountCallParticipant() {
        return signedIn()
          && resource.data.participantUids is list
          && request.auth.uid in resource.data.participantUids;
      }

      function isAccountCallParticipantAfter() {
        return signedIn()
          && request.resource.data.participantUids is list
          && request.auth.uid in request.resource.data.participantUids;
      }

      allow get, list: if isAccountCallParticipant() || isAdminClaim();

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'id',
          'type',
          'mode',
          'callerUid',
          'callerDisplayName',
          'callerPhotoURL',
          'calleeUid',
          'calleeDisplayName',
          'calleePhotoURL',
          'participantUids',
          'status',
          'startedAt',
          'acceptedAt',
          'connectedAt',
          'endedAt',
          'updatedAt',
          'endedBy',
          'endReason',
          'threadId',
          'offer',
          'answer',
          'createdBy'
        ])
        && request.resource.data.id == callId
        && request.resource.data.type == 'audio'
        && request.resource.data.mode == 'account-webrtc'
        && request.resource.data.callerUid == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.calleeUid is string
        && request.resource.data.calleeUid != request.auth.uid
        && request.resource.data.callerDisplayName is string
        && request.resource.data.callerPhotoURL is string
        && request.resource.data.calleeDisplayName is string
        && request.resource.data.calleePhotoURL is string
        && request.resource.data.participantUids is list
        && request.resource.data.participantUids.size() == 2
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.calleeUid in request.resource.data.participantUids
        && request.resource.data.status == 'ringing'
        && request.resource.data.offer == null
        && request.resource.data.answer == null;

      allow update: if isAccountCallParticipant()
        && isAccountCallParticipantAfter()
        && request.resource.data.id == resource.data.id
        && request.resource.data.type == resource.data.type
        && request.resource.data.mode == resource.data.mode
        && request.resource.data.callerUid == resource.data.callerUid
        && request.resource.data.calleeUid == resource.data.calleeUid
        && request.resource.data.participantUids == resource.data.participantUids
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'acceptedAt',
          'connectedAt',
          'endedAt',
          'updatedAt',
          'endedBy',
          'endReason',
          'offer',
          'answer'
        ])
        && request.resource.data.status in [
          'ringing',
          'accepted',
          'connecting',
          'active',
          'ended',
          'declined',
          'missed',
          'failed',
          'cancelled'
        ]
        && (
          request.resource.data.status == resource.data.status
          || request.resource.data.status in ['active', 'ended', 'failed']
          || (
            request.resource.data.status in ['accepted', 'connecting', 'declined']
            && request.auth.uid == resource.data.calleeUid
          )
          || (
            request.resource.data.status in ['missed', 'cancelled']
            && request.auth.uid == resource.data.callerUid
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['endedBy'])
          || request.resource.data.endedBy == request.auth.uid
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['offer'])
          || (
            request.auth.uid == resource.data.callerUid
            && request.resource.data.offer.type == 'offer'
            && request.resource.data.offer.sdp is string
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['answer'])
          || (
            request.auth.uid == resource.data.calleeUid
            && request.resource.data.answer.type == 'answer'
            && request.resource.data.answer.sdp is string
          )
        );

      allow delete: if false;

      match /callerCandidates/{candidateId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/accountCalls/$(callId)).data.participantUids;
        allow create: if signedIn()
          && request.auth.uid == get(/databases/$(database)/documents/accountCalls/$(callId)).data.callerUid
          && request.resource.data.keys().hasOnly([
            'candidate',
            'sdpMid',
            'sdpMLineIndex',
            'usernameFragment',
            'createdAt',
            'createdBy'
          ])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.candidate is string
          && request.resource.data.candidate.size() <= 4096;
        allow update, delete: if false;
      }

      match /calleeCandidates/{candidateId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/accountCalls/$(callId)).data.participantUids;
        allow create: if signedIn()
          && request.auth.uid == get(/databases/$(database)/documents/accountCalls/$(callId)).data.calleeUid
          && request.resource.data.keys().hasOnly([
            'candidate',
            'sdpMid',
            'sdpMLineIndex',
            'usernameFragment',
            'createdAt',
            'createdBy'
          ])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.candidate is string
          && request.resource.data.candidate.size() <= 4096;
        allow update, delete: if false;
      }
    }

    match /threads/{threadId} {
      allow get, list: if isThreadParticipantResource();

      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isThreadParticipantCreate()
        && request.resource.data.type in ['dm', 'group']
        && (!('status' in request.resource.data) || request.resource.data.status in ['active', 'archived'])
        && (!('participantCount' in request.resource.data)
          || request.resource.data.participantCount == request.resource.data.participantIds.size());

      allow update: if isThreadOwnerResource()
        || participantSafeThreadUpdateResource();

      allow delete: if false;

      match /participants/{uid} {
        allow read: if isThreadParticipant(threadId);

        allow create: if signedIn()
          && isThreadParticipant(threadId)
          && request.resource.data.uid == uid
          && (
            request.auth.uid == uid
            || isThreadOwner(threadId)
          );

        allow update: if isThreadOwner(threadId)
          || (
            signedIn()
            && isThreadParticipant(threadId)
            && participantSelfUpdateIsSafe(uid)
          );

        allow delete: if isThreadOwner(threadId);
      }

      match /messages/{messageId} {
        allow read: if isThreadParticipant(threadId);

        allow create: if isThreadParticipant(threadId)
          && request.resource.data.senderId == request.auth.uid
          && validMessageCreate()
          && dmAllowsMessageCreate(threadId);

        allow update: if isThreadParticipant(threadId)
          && (
            validMessageEdit()
            || validMessageDeleteForEveryone(threadId)
          );

        allow delete: if false;

        match /reactions/{reactionId} {
          allow read: if isThreadParticipant(threadId);

          allow create, update: if isThreadParticipant(threadId)
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.emoji is string
            && request.resource.data.emoji.size() > 0
            && request.resource.data.emoji.size() <= 16;

          allow delete: if isThreadParticipant(threadId)
            && resource.data.uid == request.auth.uid;
        }
      }

      match /typing/{uid} {
        allow read: if isThreadParticipant(threadId);

        allow create, update, delete: if signedIn()
          && isThreadParticipant(threadId)
          && request.auth.uid == uid;
      }

      match /calls/{callId} {
        allow read: if isThreadParticipant(threadId);

        allow create: if isThreadParticipant(threadId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.callerId == request.auth.uid
          && request.resource.data.participantIds is list
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.status in [
            'ringing',
            'accepted',
            'active',
            'declined',
            'missed',
            'ended',
            'failed'
          ]
          && request.resource.data.type in ['audio', 'video'];

        allow update: if isThreadParticipant(threadId)
          && request.resource.data.participantIds == resource.data.participantIds
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.callerId == resource.data.callerId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'answeredAt',
            'startedAt',
            'endedAt',
            'endedBy',
            'endReason',
            'updatedAt'
          ]);

        allow delete: if false;

        match /participants/{uid} {
          allow read: if isThreadParticipant(threadId);

          allow create, update: if isThreadParticipant(threadId)
            && request.auth.uid == uid
            && request.resource.data.uid == uid;

          allow delete: if isThreadParticipant(threadId)
            && request.auth.uid == uid;
        }

        match /offers/{uid} {
          allow read: if isThreadParticipant(threadId);

          allow create, update: if isThreadParticipant(threadId)
            && request.auth.uid == uid
            && request.resource.data.type == 'offer'
            && request.resource.data.sdp is string;

          allow delete: if false;
        }

        match /answers/{uid} {
          allow read: if isThreadParticipant(threadId);

          allow create, update: if isThreadParticipant(threadId)
            && request.auth.uid == uid
            && request.resource.data.type == 'answer'
            && request.resource.data.sdp is string;

          allow delete: if false;
        }

        match /candidates/{uid}/items/{candidateId} {
          allow read: if isThreadParticipant(threadId);

          allow create: if isThreadParticipant(threadId)
            && request.auth.uid == uid
            && request.resource.data.candidate is string;

          allow update: if false;

          allow delete: if isThreadParticipant(threadId)
            && request.auth.uid == uid;
        }
      }
    }

    match /supportThreads/{threadId} {
      allow get, list: if canReadSupportThreadResource();
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow get, list: if canReadSupportThreadById(threadId);
        allow create, update, delete: if false;
      }
    }

    match /supportGuidanceSessions/{sessionId} {
      allow get, list: if signedIn()
        && (
          hasOrderSupportClaim()
          || hasEmailSendClaim()
          || resource.data.userUid == request.auth.uid
        );
      allow create, update, delete: if false;

      match /overlays/{overlayId} {
        allow get, list: if signedIn()
          && (
            hasOrderSupportClaim()
            || hasEmailSendClaim()
            || get(/databases/$(database)/documents/supportGuidanceSessions/$(sessionId)).data.userUid == request.auth.uid
          );
        allow create, update, delete: if false;
      }
    }

    match /supportKnowledge/{docId} {
      allow get, list: if resource.data.active == true
        && resource.data.visibility == 'public';
      allow create, update, delete: if false;
    }


    match /studioProjects/{projectId} {
      allow get: if isStudioOwnerResource() || isStudioCollaboratorResource();
      allow list: if isStudioOwnerResource() || isStudioCollaboratorResource();
      allow create: if studioProjectCreateIsValid();
      allow update: if isStudioOwnerResource() && studioProjectUpdateIsValid();
      allow delete: if isStudioOwnerResource();
    }

    match /studioDawDefaults/libraryContent {
      allow read: if signedIn();
      allow write: if isOwnerAdminRole();
    }

    match /stageProjects/{projectId} {
      allow get: if isPublicStageProjectResource() || isStageOwnerResource() || isStageCollaboratorResource();
      allow list: if isPublicStageProjectResource() || isStageOwnerResource() || isStageCollaboratorResource();
      allow create: if stageProjectCreateIsValid();
      allow update: if isStageOwnerResource() && stageProjectUpdateIsValid();
      allow delete: if isStageOwnerResource();
    }

    match /operations/keyRequiredInfo {
      allow read: if true;
      allow write: if isOwnerAdminRole();
    }
    match /operations/bannerAlerts {
      allow read: if true;
      allow write: if isOwnerAdminRole();
    }

    match /adminUsers/{uid} {
      allow read: if isAdminClaim();
      allow write: if false;
    }

    match /adminLogs/{logId} {
      allow read: if hasAuditReadClaim() || hasRoleManageClaim();
      allow write: if false;
    }

    match /supportCalls/{callId} {
      allow read: if hasEmailSendClaim() || hasAuditReadClaim() || hasOrderSupportClaim();
      allow create, update: if hasEmailSendClaim() || hasOrderSupportClaim();
      allow delete: if false;
    }

    match /emailLogs/{emailId} {
      allow read: if hasAuditReadClaim() || hasEmailSendClaim();
      allow write: if false;
    }

    match /emailRateLimits/{rateLimitId} {
      allow read, write: if false;
    }

    function communityStoryKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        'storyId',
        'authorUid',
        'authorDisplayName',
        'authorUsername',
        'authorAvatarURL',
        'authorPhotoURL',
        'mediaType',
        'text',
        'caption',
        'mediaPath',
        'thumbnailPath',
        'durationSeconds',
        'background',
        'linkedPostId',
        'linkedProductId',
        'expiresAt',
        'lifetimeHours',
        'createdAt',
        'updatedAt',
        'viewCount',
        'likeCount',
        'replyCount',
        'reportCount',
        'moderationStatus',
        'status',
        'visibility'
      ]);
    }

    function communityStoryCreateIsValid(storyId) {
      return signedIn()
        && communityStoryKeysAllowed()
        && request.resource.data.storyId == storyId
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorDisplayName is string
        && request.resource.data.authorDisplayName.size() <= 120
        && request.resource.data.authorUsername is string
        && request.resource.data.authorUsername.size() <= 60
        && request.resource.data.authorAvatarURL is string
        && request.resource.data.authorAvatarURL.size() <= 900
        && (!('authorPhotoURL' in request.resource.data) || request.resource.data.authorPhotoURL is string)
        && request.resource.data.mediaType in ['text', 'image', 'video']
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500
        && (!('caption' in request.resource.data) || (request.resource.data.caption is string && request.resource.data.caption.size() <= 500))
        && request.resource.data.mediaPath is string
        && request.resource.data.mediaPath.size() <= 900
        && (!('thumbnailPath' in request.resource.data) || (request.resource.data.thumbnailPath is string && request.resource.data.thumbnailPath.size() <= 900))
        && (!('durationSeconds' in request.resource.data) || (request.resource.data.durationSeconds is number && request.resource.data.durationSeconds >= 0 && request.resource.data.durationSeconds <= 300))
        && request.resource.data.background in ['aurora', 'midnight', 'sunset', 'stage', 'mono', '']
        && request.resource.data.linkedPostId is string
        && request.resource.data.linkedPostId.size() <= 180
        && request.resource.data.linkedProductId is string
        && request.resource.data.linkedProductId.size() <= 180
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.lifetimeHours is number
        && request.resource.data.lifetimeHours >= 1
        && request.resource.data.lifetimeHours <= 48
        && request.resource.data.viewCount == 0
        && request.resource.data.likeCount == 0
        && request.resource.data.replyCount == 0
        && request.resource.data.reportCount == 0
        && request.resource.data.moderationStatus in ['not_submitted', '']
        && request.resource.data.status == 'active'
        && request.resource.data.visibility == 'public'
        && (
          (
            request.resource.data.mediaType == 'text'
            && request.resource.data.text.size() > 0
            && request.resource.data.mediaPath == ''
          )
          || (
            request.resource.data.mediaType == 'image'
            && request.resource.data.mediaPath.matches('communityStories/' + request.auth.uid + '/' + storyId + '/.*')
          )
          || (
            request.resource.data.mediaType == 'video'
            && request.resource.data.mediaPath.matches('communityStories/' + request.auth.uid + '/' + storyId + '/.*')
          )
        );
    }

    function communityStoryOwnerDeleteIsSafe() {
      return signedIn()
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.viewCount == resource.data.viewCount
        && request.resource.data.reportCount == resource.data.reportCount
        && request.resource.data.status == 'deleted'
        && request.resource.data.deletedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'deletedAt',
          'deletedBy',
          'updatedAt'
        ]);
    }

    function communityStoryAdminUpdateIsSafe() {
      return hasUserModerateClaim()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'moderationStatus',
          'moderationReason',
          'moderatedAt',
          'moderatedBy',
          'updatedAt'
        ]);
    }

    match /communityStories/{storyId} {
      allow read: if (
          resource.data.status == 'active'
          && resource.data.visibility == 'public'
          && resource.data.expiresAt > request.time
        )
        || (signedIn() && resource.data.authorUid == request.auth.uid)
        || hasUserModerateClaim();
      allow create: if communityStoryCreateIsValid(storyId);
      allow update: if communityStoryOwnerDeleteIsSafe() || communityStoryAdminUpdateIsSafe();
      allow delete: if signedIn()
        && (resource.data.authorUid == request.auth.uid || hasUserModerateClaim());

      match /views/{uid} {
        allow read: if signedIn()
          && (
            get(/databases/$(database)/documents/communityStories/$(storyId)).data.authorUid == request.auth.uid
            || hasUserModerateClaim()
          );
        allow write: if false;
      }
    }

    match /communities/{communityId} {
      allow read: if (
          resource.data.status == 'active'
          && resource.data.visibility == 'public'
        )
        || hasUserModerateClaim();
      allow create: if hasUserModerateClaim();
      allow update: if signedIn()
        && (
          (
            (resource.data.ownerUid == request.auth.uid
              || (resource.data.moderatorIds is list && request.auth.uid in resource.data.moderatorIds))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'title',
              'name',
              'description',
              'rules',
              'category',
              'imagePath',
              'imageUrl',
              'imageURL',
              'iconPath',
              'iconURL',
              'bannerImagePath',
              'bannerImageUrl',
              'bannerURL',
              'postingMode',
              'updatedAt'
            ])
          )
          || (
            hasUserModerateClaim()
          )
        );
      allow delete: if hasUserModerateClaim();
    }

    match /communityPosts/{postId} {
      allow read: if resource.data.status == 'published'
        && resource.data.visibility == 'public';

      allow create: if false;
      allow update: if signedIn()
        && (
          (
            resource.data.authorUid == request.auth.uid
            && request.resource.data.authorUid == resource.data.authorUid
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.counts == resource.data.counts
            && request.resource.data.official == resource.data.official
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'title',
              'body',
              'tags',
              'updatedAt'
            ])
          )
          || (
            hasUserModerateClaim()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'visibility',
              'moderationStatus',
              'moderationReason',
              'moderatedAt',
              'moderatedBy',
              'updatedAt'
            ])
          )
        );
      allow delete: if signedIn()
        && (resource.data.authorUid == request.auth.uid || hasUserModerateClaim());

      match /likes/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if false;
      }

      match /dislikes/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if false;
      }

      match /saves/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if false;
      }

      match /shares/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if false;
      }

      match /comments/{commentId} {
        allow read: if resource.data.status == 'visible'
          && get(/databases/$(database)/documents/communityPosts/$(postId)).data.status == 'published'
          && get(/databases/$(database)/documents/communityPosts/$(postId)).data.visibility == 'public';
        allow create: if false;
        allow update: if signedIn()
          && (
            (
              resource.data.authorUid == request.auth.uid
              && request.resource.data.authorUid == resource.data.authorUid
              && request.resource.data.postId == resource.data.postId
              && request.resource.data.parentCommentId == resource.data.parentCommentId
              && request.resource.data.createdAt == resource.data.createdAt
              && request.resource.data.replyCount == resource.data.replyCount
              && request.resource.data.likeCount == resource.data.likeCount
              && request.resource.data.dislikeCount == resource.data.dislikeCount
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status',
                'body',
                'deletedAt',
                'deletedBy',
                'updatedAt'
              ])
              && request.resource.data.status == 'deleted'
            )
            || (
              hasUserModerateClaim()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status',
                'moderationStatus',
                'moderationReason',
                'moderatedAt',
                'moderatedBy',
                'updatedAt'
              ])
            )
          );
        allow delete: if false;

        match /likes/{uid} {
          allow read: if signedIn() && request.auth.uid == uid;
          allow write: if false;
        }

        match /dislikes/{uid} {
          allow read: if signedIn() && request.auth.uid == uid;
          allow write: if false;
        }
      }
    }

    match /musicReleases/{releaseId} {
      allow read: if resource.data.status == 'published'
        && resource.data.visibility == 'public';
      allow write: if false;
    }

    match /musicTracks/{trackId} {
      allow read: if resource.data.status == 'published'
        && resource.data.visibility == 'public';
      allow write: if false;
    }

    match /musicLiveStreams/{streamId} {
      allow read: if resource.data.status == 'live'
        && (
          resource.data.visibility in ['public', 'unlisted']
          || resource.data.accessMode in ['public', 'unlisted', 'password']
        );
      allow update: if signedIn()
        && (resource.data.hostUid == request.auth.uid || isAdminClaim())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title',
          'description',
          'coverArtURL',
          'coverArtPath',
          'coverArtSource',
          'tags',
          'visibility',
          'accessMode',
          'passwordProtected',
          'category',
          'updatedAt',
          'lastMetadataUpdateAt'
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.title.size() <= 90
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 1200
        && request.resource.data.coverArtURL is string
        && request.resource.data.coverArtURL.size() <= 1000
        && request.resource.data.visibility in ['public', 'unlisted', 'private']
        && request.resource.data.accessMode in ['public', 'unlisted', 'private', 'password']
        && request.resource.data.category in ['music', 'podcast', 'radio', 'interview', 'listening_party', 'creator_talk', 'other']
        && (resource.data.status != 'ended' || isAdminClaim());
      allow create, delete: if false;

      match /chatMessages/{messageId} {
        allow read: if signedIn()
          && get(/databases/$(database)/documents/musicLiveStreams/$(streamId)).data.status == 'live'
          && get(/databases/$(database)/documents/musicLiveStreams/$(streamId)).data.visibility in ['public', 'unlisted']
          && resource.data.status == 'visible';
        allow create: if signedIn()
          && get(/databases/$(database)/documents/musicLiveStreams/$(streamId)).data.status == 'live'
          && get(/databases/$(database)/documents/musicLiveStreams/$(streamId)).data.visibility in ['public', 'unlisted']
          && request.resource.data.keys().hasOnly([
            'messageId',
            'streamId',
            'uid',
            'displayName',
            'photoURL',
            'text',
            'createdAt',
            'status',
            'moderationFlags'
          ])
          && request.resource.data.streamId == streamId
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.status == 'visible'
          && (!exists(/databases/$(database)/documents/users/$(request.auth.uid))
            || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.suspended != true
              && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountStatus != 'suspended'));
        allow update, delete: if false;
      }

      match /sequenceItems/{itemId} {
        allow read: if get(/databases/$(database)/documents/musicLiveStreams/$(streamId)).data.status == 'live'
          && (
            get(/databases/$(database)/documents/musicLiveStreams/$(streamId)).data.visibility in ['public', 'unlisted']
            || get(/databases/$(database)/documents/musicLiveStreams/$(streamId)).data.accessMode in ['public', 'unlisted', 'password']
          );
        allow write: if false;
      }

      match /presence/{presenceId} {
        allow read: if signedIn()
          && (get(/databases/$(database)/documents/musicLiveStreams/$(streamId)).data.hostUid == request.auth.uid || isAdminClaim());
        allow write: if false;
      }

      match /reactions/{uid} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdminClaim());
        allow write: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if canReadReportsClaim();
      allow write: if false;
    }

    match /productModeration/{moderationId} {
      allow read: if hasProductReviewClaim();
      allow write: if false;

      match /events/{eventId} {
        allow read: if hasProductReviewClaim();
        allow write: if false;
      }
    }

        match /supportForms/{formId} {
      allow create: if request.resource.data.keys().hasOnly([
          'name',
          'email',
          'username',
          'subject',
          'message',
          'status',
          'source',
          'adminNote',
          'assignedTo',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 254
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() <= 180
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 5000
        && request.resource.data.status == 'new'
        && request.resource.data.source == 'support_page';

      allow read, update: if hasEmailSendClaim() || hasOrderSupportClaim() || hasAuditReadClaim();
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || resource.data.buyerUid == request.auth.uid);
      allow write: if false;
    }

    match /creatorLedger/{ledgerEntryId} {
      allow read: if signedIn()
        && (resource.data.creatorUid == request.auth.uid || hasAuditReadClaim() || hasOrderSupportClaim());
      allow write: if false;
    }

    match /stripeConnectAccounts/{uid} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /productEngagement/{productId} {
      allow read: if true;
      allow write: if false;

      match /users/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if false;
      }
    }

  }
}
