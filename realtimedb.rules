{
  "rules": {
    ".read": false,
    ".write": false,
    "livePresence": {
      "$streamId": {
        ".read": true,
        "playbackDemand": {
          "$viewerSessionId": {
            ".write": "(!newData.exists()) || ($viewerSessionId.matches(/^[A-Za-z0-9_-]{8,80}$/) && newData.hasChildren(['state', 'joinedAt', 'lastSeenAt', 'tabId']) && ((auth === null && (!newData.child('uid').exists() || newData.child('uid').val() === null)) || (auth !== null && newData.child('uid').isString() && newData.child('uid').val() === auth.uid)))",
            ".validate": "!newData.exists() || newData.hasChildren(['state', 'joinedAt', 'lastSeenAt', 'tabId'])",
            "state": {
              ".validate": "newData.isString() && (newData.val() === 'buffering' || newData.val() === 'listening' || newData.val() === 'paused')"
            },
            "joinedAt": {
              ".validate": "newData.isNumber()"
            },
            "lastSeenAt": {
              ".validate": "newData.isNumber()"
            },
            "tabId": {
              ".validate": "newData.isString() && newData.val().length <= 120"
            },
            "uid": {
              ".validate": "(auth === null && newData.val() === null) || (auth !== null && newData.isString() && newData.val() === auth.uid)"
            },
            "userAgentHash": {
              ".validate": "newData.isString() && newData.val().length <= 160"
            },
            "$other": {
              ".validate": false
            }
          },
          ".indexOn": ["state", "lastSeenAt", "uid"]
        },
        "host": {
          ".read": true,
          ".write": "auth !== null && newData.hasChildren(['uid', 'state', 'lastSeenAt', 'broadcasting', 'hostSessionId']) && newData.child('uid').isString() && newData.child('uid').val() === auth.uid",
          ".validate": "newData.hasChildren(['uid', 'state', 'lastSeenAt', 'broadcasting', 'hostSessionId'])",
          "uid": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "state": {
            ".validate": "newData.isString() && (newData.val() === 'online' || newData.val() === 'offline')"
          },
          "lastSeenAt": {
            ".validate": "newData.isNumber()"
          },
          "broadcasting": {
            ".validate": "newData.isBoolean()"
          },
          "hostSessionId": {
            ".validate": "newData.isString() && newData.val().matches(/^host_[A-Za-z0-9_-]{8,80}$/)"
          },
          "$other": {
            ".validate": false
          }
        },
        "viewerCounts": {
          ".read": true,
          ".write": false,
          ".indexOn": ["updatedAt"]
        },
        "$other": {
          ".read": false,
          ".write": false
        }
      }
    }
  }
}
