rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminStorageWriter() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.roleManage == true
          || request.auth.token.settingsManage == true
        );
    }

    function isThreadParticipant(threadId) {
      return signedIn()
        && request.auth.uid in firestore.get(/databases/(default)/documents/threads/$(threadId)).data.participantIds;
    }

    function isThreadOwner(threadId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/threads/$(threadId)).data.createdBy == request.auth.uid;
    }

    function isProductOwner(productId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/products/$(productId)).data.artistId == request.auth.uid;
    }

    function isImageUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    function isAudioUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('audio/.*');
    }

    function isVideoUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('video/.*');
    }

    function isPdfUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('application/pdf');
    }

    function isMessageAttachmentUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType.matches('audio/.*')
          || request.resource.contentType.matches('text/.*')
          || request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/zip')
          || request.resource.contentType.matches('application/x-zip-compressed')
          || request.resource.contentType.matches('application/msword')
          || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document')
          || request.resource.contentType.matches('application/octet-stream')
        );
    }

    function isStudioProjectOwner(projectId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/studioProjects/$(projectId)).data.ownerId == request.auth.uid;
    }

    function isStudioProjectCollaborator(projectId) {
      return signedIn()
        && request.auth.uid in firestore.get(/databases/(default)/documents/studioProjects/$(projectId)).data.collaboratorIds;
    }

    function canReadStudioProject(projectId) {
      return isStudioProjectOwner(projectId) || isStudioProjectCollaborator(projectId);
    }

    function canWriteStudioProject(projectId) {
      return isStudioProjectOwner(projectId);
    }

    function isStageProjectOwner(projectId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/stageProjects/$(projectId)).data.ownerId == request.auth.uid;
    }

    function isStageProjectCollaborator(projectId) {
      return signedIn()
        && request.auth.uid in firestore.get(/databases/(default)/documents/stageProjects/$(projectId)).data.collaboratorIds;
    }

    function canReadStageProject(projectId) {
      return isStageProjectOwner(projectId) || isStageProjectCollaborator(projectId);
    }

    function canWriteStageProject(projectId) {
      return isStageProjectOwner(projectId);
    }

    function isJsonUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('application/json');
    }

    function isModelUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && (
          request.resource.contentType.matches('model/.*')
          || request.resource.contentType.matches('application/octet-stream')
          || request.resource.contentType.matches('application/gltf-binary')
          || request.resource.contentType.matches('model/gltf-binary')
        );
    }

    // Public brand/site assets (logos, hero videos, etc.) used across unauthenticated pages.
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /legal/agreements/{agreementId}/{fileName} {
      allow read: if signedIn();
      allow write: if isAdminStorageWriter()
        && request.resource != null
        && request.resource.size <= 2 * 1024 * 1024
        && agreementId == 'marketplace-product-seller-agreement'
        && fileName.matches('v[0-9]+\\.md')
        && (
          request.resource.contentType.matches('text/markdown')
          || request.resource.contentType.matches('text/plain')
          || request.resource.contentType.matches('application/octet-stream')
        );
    }

    match /agreements/{agreementId}/{fileName} {
      allow read: if true;
      allow write: if isAdminStorageWriter()
        && request.resource != null
        && request.resource.size <= 2 * 1024 * 1024
        && fileName.matches('v[0-9]+\\.md')
        && (
          request.resource.contentType.matches('text/markdown')
          || request.resource.contentType.matches('text/plain')
          || request.resource.contentType.matches('application/octet-stream')
        );
    }

    match /users/{uid}/stage/custom-assets/{assetId}/{version}/{fileName} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn()
        && request.auth.uid == uid
        && request.resource != null
        && request.resource.size <= 100 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || isJsonUpload(100 * 1024 * 1024)
          || isModelUpload(100 * 1024 * 1024)
        );
    }

    // User-owned profile media uploads (avatar/banner).
    match /users/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /communityStories/{uid}/{storyId}/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && request.auth.uid == uid
        && isImageUpload(10 * 1024 * 1024);
    }

    match /products/{productId}/thumbnails/{fileName} {
      allow read: if true;
      allow write: if isProductOwner(productId) && isImageUpload(5 * 1024 * 1024);
    }

    match /products/{productId}/cover/{fileName} {
      allow read: if true;
      allow write: if isProductOwner(productId) && isImageUpload(10 * 1024 * 1024);
    }

    match /products/{productId}/gallery/{fileName} {
      allow read: if true;
      allow write: if isProductOwner(productId) && isImageUpload(15 * 1024 * 1024);
    }

    match /products/{productId}/audio-previews/{fileName} {
      allow read: if true;
      allow write: if isProductOwner(productId) && isAudioUpload(50 * 1024 * 1024);
    }

    match /products/{productId}/video-previews/{fileName} {
      allow read: if true;
      allow write: if isProductOwner(productId) && isVideoUpload(250 * 1024 * 1024);
    }

    match /products/{productId}/downloads/{fileName} {
      allow read: if false;
      allow write: if isProductOwner(productId) && request.resource != null && request.resource.size <= 1024 * 1024 * 1024;
    }

    match /products/{productId}/files/{fileId}/{fileName} {
      allow read: if false;
      allow write: if isProductOwner(productId) && request.resource != null && request.resource.size <= 512 * 1024 * 1024;
    }

    match /products/{productId}/licenses/{fileName} {
      allow read: if false;
      allow write: if isProductOwner(productId) && isPdfUpload(20 * 1024 * 1024);
    }

    match /products/{productId}/{allPaths=**} {
      allow read, write: if false;
    }


    match /studioProjects/{projectId}/audio/{fileName} {
      allow read: if canReadStudioProject(projectId);
      allow write: if canWriteStudioProject(projectId)
        && isAudioUpload(250 * 1024 * 1024);
    }

    match /studioProjects/{projectId}/images/{fileName} {
      allow read: if canReadStudioProject(projectId);
      allow write: if canWriteStudioProject(projectId)
        && isImageUpload(25 * 1024 * 1024);
    }

    match /studioProjects/{projectId}/stems/{fileName} {
      allow read: if canReadStudioProject(projectId);
      allow write: if canWriteStudioProject(projectId)
        && isAudioUpload(500 * 1024 * 1024);
    }

    match /studioProjects/{projectId}/exports/{fileName} {
      allow read: if canReadStudioProject(projectId);
      allow write: if canWriteStudioProject(projectId)
        && request.resource != null
        && request.resource.size <= 1024 * 1024 * 1024
        && (
          request.resource.contentType.matches('audio/.*')
          || request.resource.contentType.matches('application/zip')
          || request.resource.contentType.matches('application/octet-stream')
        );
    }

    match /studioProjects/{projectId}/attachments/{fileName} {
      allow read: if canReadStudioProject(projectId);
      allow write: if canWriteStudioProject(projectId)
        && request.resource != null
        && request.resource.size <= 512 * 1024 * 1024;
    }

    match /studioProjects/{projectId}/{allPaths=**} {
      allow read, write: if false;
    }

    match /stage-projects/{userId}/{projectId}/exports/{fileName} {
      allow read: if canReadStageProject(projectId);
      allow write: if signedIn()
        && request.auth.uid == userId
        && canWriteStageProject(projectId)
        && request.resource != null
        && request.resource.size <= 250 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/zip')
          || request.resource.contentType.matches('application/octet-stream')
        );
    }

    match /stage-projects/{userId}/{projectId}/snapshots/{fileName} {
      allow read: if canReadStageProject(projectId);
      allow write: if signedIn()
        && request.auth.uid == userId
        && canWriteStageProject(projectId)
        && isImageUpload(25 * 1024 * 1024);
    }

    match /stage-projects/{userId}/{projectId}/attachments/{fileName} {
      allow read: if canReadStageProject(projectId);
      allow write: if signedIn()
        && request.auth.uid == userId
        && canWriteStageProject(projectId)
        && request.resource != null
        && request.resource.size <= 250 * 1024 * 1024;
    }

    match /stage-projects/{userId}/{projectId}/{allPaths=**} {
      allow read, write: if false;
    }

    match /stage/projects/{projectId}/exports/{fileName} {
      allow read: if canReadStageProject(projectId);
      allow write: if canWriteStageProject(projectId)
        && request.resource != null
        && request.resource.size <= 250 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/json')
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/zip')
          || request.resource.contentType.matches('application/octet-stream')
        );
    }

    match /stage/projects/{projectId}/snapshots/{fileName} {
      allow read: if canReadStageProject(projectId);
      allow write: if canWriteStageProject(projectId)
        && isImageUpload(25 * 1024 * 1024);
    }

    match /stage/projects/{projectId}/assets/{assetPath=**} {
      allow read: if canReadStageProject(projectId);
      allow write: if canWriteStageProject(projectId)
        && request.resource != null
        && request.resource.size <= 100 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || isJsonUpload(100 * 1024 * 1024)
          || isModelUpload(100 * 1024 * 1024)
        );
    }

    match /stage/projects/{projectId}/{allPaths=**} {
      allow read, write: if false;
    }

    match /threads/{threadId}/messages/{messageId}/attachments/{fileName} {
      allow read: if isThreadParticipant(threadId);
      allow write: if isThreadParticipant(threadId)
        && isMessageAttachmentUpload(256 * 1024 * 1024);
    }

    match /threads/{threadId}/avatar/{fileName} {
      allow read: if isThreadParticipant(threadId);
      allow write: if isThreadOwner(threadId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
